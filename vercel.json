{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/c/:hash([A-Za-z0-9]{8,16})",
      "destination": "/api/c?hash=:hash"
    }
  ],
  "redirects": [
    { "source": "/index.html",   "destination": "/",               "permanent": true },
    { "source": "/beta.html",    "destination": "/beta",           "permanent": true },
    { "source": "/privacy.html", "destination": "/legal/privacy",  "permanent": true },
    { "source": "/terms.html",   "destination": "/legal/terms",    "permanent": true },
    { "source": "/engine",       "destination": "/",               "permanent": false },
    { "source": "/engine/:path*","destination": "/",               "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
