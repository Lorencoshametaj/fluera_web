# Fill these in from Supabase → Project Settings → API
# Both values are public by design (the anon key only grants access to
# the `submit_waitlist` RPC, which validates + inserts server-side).
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ─── Analytics (Plausible) ─────────────────────────────────────────────
# Plausible is GDPR-compliant, cookieless, no consent banner needed.
# Aligns with Fluera's "no ad-tech" brand stance (see /manifesto).
#
# Setup steps:
#   1. Create site at https://plausible.io/sites (€9/mo, 10k pageviews/mo)
#      — or self-host (https://github.com/plausible/community-edition)
#   2. Set PUBLIC_PLAUSIBLE_DOMAIN to the domain you registered (e.g. fluera.dev)
#   3. Add the env var in Vercel/Pages dashboard for production builds
#   4. Verify events firing in Plausible dashboard within 5 min of deploy
#
# When set, the script auto-loads in <Head>. Leave blank to skip (zero impact).
# Default script (`script.outbound-links.tagged-events.js`) gives:
#   - Auto outbound link tracking (Stripe, App Store, etc.)
#   - Custom events via `class="plausible-event-name=Foo+Bar"`
#
# Custom events already tagged in code:
#   - Beta CTA Click (Nav desktop, Nav mobile, ...)
#   - Locale Switch (with `to=<code>` prop)
# Add more by appending `plausible-event-name=YourEvent` to any clickable element.
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.outbound-links.tagged-events.js
