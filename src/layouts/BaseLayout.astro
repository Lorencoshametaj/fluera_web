---
import "@/styles/global.css";
import Head from "@/components/Head.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { localeFromPathname, t } from "@/lib/i18n";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  canonical?: string;
  locale?: "en" | "it";
  hideChrome?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
}

const detectedLocale = localeFromPathname(Astro.url.pathname);
const { locale = detectedLocale, hideChrome = false, bodyClass = "", ...headProps } = Astro.props;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <Head {...headProps} locale={locale} />
  </head>
  <body class={`min-h-screen bg-ink-950 text-paper-100 antialiased overflow-x-hidden ${bodyClass}`}>
    {!hideChrome && (
      <a href="#main-content" class="skip-link">{t("nav.skipToContent", locale)}</a>
    )}
    {!hideChrome && <Nav />}
    <main id="main-content" class={hideChrome ? "" : "pt-16"} tabindex="-1">
      <slot />
    </main>
    {!hideChrome && <Footer />}

    <style is:global>
      .skip-link {
        position: fixed;
        top: -100px;
        left: 1rem;
        z-index: 100;
        padding: 0.75rem 1.25rem;
        background: theme("colors.accent.ink");
        color: theme("colors.paper.50");
        border-radius: 0.5rem;
        font-family: theme("fontFamily.sans");
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: top 0.15s ease-out;
      }
      .skip-link:focus-visible {
        top: 1rem;
        outline: 2px solid theme("colors.accent.glow");
        outline-offset: 2px;
      }
      main:focus-visible {
        outline: none;
      }
    </style>
  </body>
</html>
