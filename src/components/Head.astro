---
import { SITE, languageSwitchHref } from "@/lib/site";
import { LOCALES, DEFAULT_LOCALE, type Locale } from "@/lib/i18n";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  canonical?: string;
  locale?: Locale;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /**
   * Explicit hreflang alternates per locale (relative or absolute URLs). Used by
   * dynamic [slug].astro templates that know their localized counterparts via
   * content collection lookup. When absent, falls back to `languageSwitchHref()`
   * which routes to each locale's matching static page or homepage.
   */
  alternates?: Partial<Record<Locale, string>>;
}

const {
  title,
  description = SITE.description,
  ogImage = "/og/default.png",
  noIndex = false,
  canonical,
  locale = "en",
  jsonLd,
  alternates,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = new URL(ogImage, SITE.url).toString();
const fullTitle = title === SITE.name ? SITE.name : `${title} — ${SITE.name}`;

const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];

// og:locale maps to a BCP 47 territory tag — needed by Facebook/LinkedIn parsers.
const OG_LOCALE: Record<Locale, string> = {
  en: "en_US", it: "it_IT", es: "es_ES", "pt-br": "pt_BR",
  fr: "fr_FR", de: "de_DE", ja: "ja_JP", ko: "ko_KR",
  hi: "hi_IN", ar: "ar_SA", pl: "pl_PL", nl: "nl_NL",
  sv: "sv_SE", da: "da_DK", no: "nb_NO", fi: "fi_FI",
};

// hreflang code = BCP 47 (Google requires region casing: pt-BR not pt-br).
const HREFLANG_CODE: Record<Locale, string> = {
  en: "en", it: "it", es: "es", "pt-br": "pt-BR",
  fr: "fr", de: "de", ja: "ja", ko: "ko",
  hi: "hi", ar: "ar", pl: "pl", nl: "nl",
  sv: "sv", da: "da", no: "no", fi: "fi",
};

// Build hreflang alternates for all 16 locales + x-default (= EN root).
// Explicit alternates win; otherwise fall back to languageSwitchHref() which
// routes to each locale's matching static page (or homepage if untranslated).
const hreflangLinks = LOCALES.map((loc) => {
  const explicit = alternates?.[loc];
  const path = explicit ?? languageSwitchHref(Astro.url.pathname, loc);
  return {
    code: HREFLANG_CODE[loc],
    href: new URL(path, SITE.url).toString(),
  };
});
const xDefaultHref = new URL(
  alternates?.[DEFAULT_LOCALE] ?? languageSwitchHref(Astro.url.pathname, DEFAULT_LOCALE),
  SITE.url,
).toString();

const plausibleOrigin = (() => {
  try {
    return new URL(import.meta.env.PUBLIC_PLAUSIBLE_SRC
      ?? "https://plausible.io/js/script.outbound-links.tagged-events.js").origin;
  } catch {
    return null;
  }
})();

// Plausible analytics — opt-in via env var. The "outbound-links + tagged-events"
// script gives us automatic outbound link tracking PLUS support for custom events
// triggered by `class="plausible-event-name=Foo+Bar"` on any element. ~1KB extra.
// Setup: add `PUBLIC_PLAUSIBLE_DOMAIN=fluera.dev` to .env once Plausible account
// is provisioned. Without env var, no script is emitted (zero impact, GDPR-safe).
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const plausibleSrc = import.meta.env.PUBLIC_PLAUSIBLE_SRC
  ?? "https://plausible.io/js/script.outbound-links.tagged-events.js";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Theme init (anti-FOUC): apply saved or OS-preferred theme before first paint -->
<script is:inline>
  (function () {
    try {
      var t = localStorage.getItem("theme");
      if (t !== "light" && t !== "dark") {
        t = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      }
      if (t === "light") document.documentElement.classList.add("light");
    } catch (e) {}
  })();
</script>

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

{/* hreflang alternates — one per locale + x-default. Google uses these to
    serve the right localized URL in SERPs based on user's language settings.
    Both HTML head AND sitemap.xml emit hreflang; Google reads both. */}
{hreflangLinks.map((h) => (
  <link rel="alternate" hreflang={h.code} href={h.href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />

{noIndex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}

<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={OG_LOCALE[locale] ?? "en_US"} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={`@${SITE.company.twitter}`} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<meta name="theme-color" content="#05070c" />
<meta name="color-scheme" content="dark" />

<link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
{plausibleOrigin && (
  <>
    <link rel="dns-prefetch" href={plausibleOrigin} />
    <link rel="preconnect" href={plausibleOrigin} crossorigin />
  </>
)}
{/* Async font loading — preload then swap to stylesheet. Falls back via <noscript>. */}
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  />
</noscript>

{jsonLdArray.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}

{plausibleDomain && (
  <script
    is:inline
    defer
    data-domain={plausibleDomain}
    src={plausibleSrc}
  />
)}
