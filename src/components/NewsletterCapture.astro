---
import { NEWSLETTER } from "@/lib/site";

export interface Props {
  headline?: string;
  sub?: string;
  buttonLabel?: string;
  variant?: "inline" | "card";
}
const {
  headline = "One email a month. Only the good stuff.",
  sub = "Cognitive-science deep dives, product notes, and — when we have them — research findings from the Fluera beta. Unsubscribe anytime, because that is what a real-human newsletter looks like.",
  buttonLabel = "Subscribe",
  variant = "card",
} = Astro.props;

const isWired = Boolean(NEWSLETTER.username);
const endpoint = isWired ? NEWSLETTER.endpoint(NEWSLETTER.username) : "";
---

<aside class={variant === "card" ? "card p-7 md:p-9" : ""}>
  <h3 class="font-serif text-xl md:text-2xl text-paper-50 mb-3">{headline}</h3>
  <p class="text-sm text-paper-300 leading-relaxed mb-6 max-w-prose">{sub}</p>

  <form
    class="newsletter-form flex flex-col sm:flex-row gap-3 max-w-md"
    data-newsletter-form
    data-newsletter-endpoint={endpoint}
    data-newsletter-wired={isWired ? "true" : "false"}
  >
    <label class="sr-only" for="newsletter-email">Email</label>
    <input
      id="newsletter-email"
      type="email"
      name="email"
      required
      autocomplete="email"
      class="newsletter-input flex-1"
      placeholder="you@domain.com"
    />
    <button type="submit" class="btn-primary whitespace-nowrap px-5">
      {buttonLabel}
    </button>
  </form>

  <p class="newsletter-status text-xs font-mono uppercase tracking-widest mt-4 hidden" data-newsletter-status></p>

  {!isWired && (
    <p class="text-[11px] font-mono uppercase tracking-widest text-ink-500 mt-4">
      Newsletter wiring arrives in Phase 2 — today the form captures your email so we can backfill it when we pick a provider.
    </p>
  )}
</aside>

<style>
  .newsletter-input {
    background: theme("colors.ink.900");
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 9999px;
    padding: 0.75rem 1.25rem;
    color: theme("colors.paper.50");
    font-size: 0.95rem;
    transition: all 0.2s;
  }
  .newsletter-input:focus {
    outline: none;
    border-color: theme("colors.accent.ink");
    box-shadow: 0 0 0 3px rgb(45 74 222 / 0.18);
  }

  /* ── Light-theme overrides for scoped newsletter styles ────────────────── */
  :global(html.light) .newsletter-input {
    background: #ffffff;
    border-color: rgb(0 0 0 / 0.10);
    color: #16181d;
  }
</style>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>("[data-newsletter-form]");

  forms.forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLElement>("[data-newsletter-status]");
    const endpoint = form.dataset.newsletterEndpoint ?? "";
    const wired = form.dataset.newsletterWired === "true";

    const showStatus = (message: string, kind: "ok" | "warn" | "bad") => {
      if (!status) return;
      status.textContent = message;
      status.classList.remove("hidden", "text-accent-glow", "text-signal-warn", "text-signal-bad");
      const klass = kind === "ok" ? "text-accent-glow" : kind === "warn" ? "text-signal-warn" : "text-signal-bad";
      status.classList.add(klass);
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const emailInput = form.elements.namedItem("email") as HTMLInputElement;
      const email = emailInput.value.trim();
      if (!email) return;

      const submitBtn = form.querySelector<HTMLButtonElement>("button[type=submit]");
      if (submitBtn) submitBtn.disabled = true;

      if (wired && endpoint) {
        // Wired mode: POST to Buttondown public embed endpoint.
        // No API key exposed — this is the same endpoint Buttondown's own
        // <iframe> embed forms use. Server-side validates the email and
        // sends the confirmation email (double opt-in).
        try {
          const body = new URLSearchParams({ email });
          const res = await fetch(endpoint, {
            method: "POST",
            mode: "no-cors", // Buttondown's embed endpoint does not return CORS headers
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: body.toString(),
          });
          // With mode: "no-cors" we cannot read res.ok — assume success if no throw.
          // Buttondown sends the confirmation email regardless; failure modes are
          // typically invalid email format (caught by browser) or already-subscribed.
          showStatus("Check your inbox to confirm — we sent a one-tap link.", "ok");
          form.reset();
        } catch (err) {
          showStatus("Something went wrong. Try again in a moment.", "bad");
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      } else {
        // Fallback mode: store in localStorage so we can backfill once a provider is wired.
        try {
          const stored = JSON.parse(localStorage.getItem("fluera-newsletter-emails") || "[]");
          if (!stored.includes(email)) stored.push(email);
          localStorage.setItem("fluera-newsletter-emails", JSON.stringify(stored));
        } catch { /* ignore */ }
        showStatus("Got it. We'll backfill when the provider is wired up.", "warn");
        form.reset();
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });
</script>
