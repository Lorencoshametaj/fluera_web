---
export interface DocLink {
  title: string;
  href: string;
  current?: boolean;
}

export interface DocSection {
  label: string;
  slug: string;
  links: DocLink[];
}

export interface Props {
  sections: DocSection[];
  rootHref: string;
  rootLabel: string;
}

const { sections, rootHref, rootLabel } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<aside class="docs-sidebar" aria-label="Documentation navigation">
  <div class="px-4 py-5 border-b border-white/[0.06]">
    <a href={rootHref} class="flex items-center gap-2 text-sm font-medium text-paper-50 hover:text-accent-glow transition-colors">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {rootLabel}
    </a>
  </div>

  <nav class="px-2 py-4 space-y-6">
    {sections.map((sec) => (
      <div>
        <p class="eyebrow px-3 mb-2 text-ink-500">{sec.label}</p>
        <ul class="list-none p-0 space-y-0.5">
          {sec.links.map((link) => {
            const isActive = currentPath === link.href.replace(/\/$/, "");
            return (
              <li>
                <a
                  href={link.href}
                  class={`block px-3 py-1.5 rounded-md text-sm transition-colors ${
                    isActive
                      ? "bg-accent-ink/[0.15] text-accent-glow font-medium"
                      : "text-paper-300 hover:text-paper-50 hover:bg-white/[0.04]"
                  }`}
                  aria-current={isActive ? "page" : undefined}
                >
                  {link.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .docs-sidebar {
    position: sticky;
    top: 4rem; /* under fixed nav */
    height: calc(100vh - 4rem);
    overflow-y: auto;
    border-inline-end: 1px solid rgb(255 255 255 / 0.05);
  }

  /* ── Light-theme overrides for scoped doc-sidebar styles ───────────────── */
  :global(html.light) .docs-sidebar {
    border-inline-end-color: rgb(0 0 0 / 0.06);
  }
</style>
