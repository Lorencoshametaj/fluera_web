---
import { Image } from "astro:assets";
import logo from "@/assets/fluera_logo_tile.png";
import { SITE, localizedHref } from "@/lib/site";
import { localeFromPathname, t } from "@/lib/i18n";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const locale = localeFromPathname(pathname);
const href = (target: string) => localizedHref(target, locale);

const year = new Date().getFullYear();

const columns = [
  {
    heading: "footer.col.product",
    items: [
      { key: "footer.product.features",  href: "/features" },
      { key: "footer.product.download",  href: "/download" },
      { key: "footer.product.pricing",   href: "/pricing" },
      { key: "footer.product.demo",      href: "/demo", external: true },
      { key: "footer.product.changelog", href: "/changelog" },
    ],
  },
  {
    heading: "footer.col.science",
    items: [
      { key: "footer.science.cycle",        href: "/science#learning-cycle" },
      { key: "footer.science.principles",   href: "/science#principles" },
      { key: "footer.science.authors",      href: "/science#authors" },
      { key: "footer.science.bibliography", href: "/research" },
    ],
  },
  {
    heading: "footer.col.company",
    items: [
      { key: "footer.company.about",     href: "/about" },
      { key: "footer.company.manifesto", href: "/manifesto" },
      { key: "footer.company.blog",      href: "/blog" },
      { key: "footer.company.contact",   href: "/contact" },
      { key: "footer.company.beta",      href: "/beta" },
    ],
  },
  {
    heading: "footer.col.trust",
    items: [
      { key: "footer.trust.security",      href: "/security" },
      { key: "footer.trust.architecture",  href: "/security/architecture" },
      { key: "footer.trust.subprocessors", href: "/security/sub-processors" },
      { key: "footer.trust.privacy",       href: "/legal/privacy" },
      { key: "footer.trust.terms",         href: "/legal/terms" },
    ],
  },
] as const;
---

<footer class="border-t border-white/[0.06] bg-ink-950 mt-16">
  <div class="container-site py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10 mb-14">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <Image
            src={logo}
            alt=""
            width={28}
            height={28}
            densities={[1, 2]}
            format="webp"
            quality={90}
            class="h-7 w-7 rounded-md object-contain"
            loading="lazy"
            decoding="async"
          />
          <span class="text-sm font-medium text-paper-100">{SITE.name}</span>
        </div>
        <p class="text-sm text-ink-500 leading-relaxed max-w-xs">
          {t("footer.tagline", locale)}
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h2 class="eyebrow mb-4">{t(col.heading, locale)}</h2>
          <ul class="space-y-2.5 text-sm">
            {col.items.map((item) => {
              const isExternal = "external" in item && item.external;
              return (
                <li>
                  <a
                    href={isExternal ? item.href : href(item.href)}
                    class="text-paper-300 hover:text-paper-50 transition-colors"
                    {...(isExternal ? { rel: "noopener" } : {})}
                  >
                    {t(item.key, locale)}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-8 border-t border-white/[0.04] text-xs text-ink-500">
      <p>
        © {year} {SITE.company.legalName} <span class="divider-dot"></span> {SITE.company.city} <span class="divider-dot"></span>
        <a href={`mailto:${SITE.company.contactEmail}`} class="hover:text-paper-200">
          {SITE.company.contactEmail}
        </a>
      </p>
      <div class="flex items-center gap-6">
        <a href={SITE.social.github} class="hover:text-paper-200" rel="noopener">GitHub</a>
        <a href={SITE.social.twitter} class="hover:text-paper-200" rel="noopener">Twitter</a>
      </div>
    </div>
  </div>
</footer>
