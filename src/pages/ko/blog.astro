---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft && data.lang === "ko"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categoryLabel: Record<string, string> = {
  "cognitive-science": "인지 과학",
  "product": "제품",
  "engineering": "엔지니어링",
  "field-notes": "현장 노트",
};

function formatDate(d: Date) {
  return d.toLocaleDateString("ko-KR", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
  title="블로그"
  description="응용 인지 과학. 제품 노트. 엔지니어링 세부 사항. 쓸 가치가 있는 것들."
  locale="ko"
>
  <PageHero
    kicker="블로그"
    title="응용 인지 과학."
    description="우리가 무엇을 만들고 있고 왜인지에 대한 노트. 리스트 기사 없음. 사고 리더십 없음. 읽을 수 있을 만큼 짧고, 의미가 있을 만큼 긴."
  />

  <section class="py-12 md:py-16">
    <div class="container-site">
      <ul class="space-y-4 list-none p-0 max-w-4xl">
        {posts.map((p) => (
          <li>
            <a href={`/ko/blog/${p.id.replace(/\.ko$/, "")}`} class="block card p-6 md:p-8 hover:border-accent-glow/40 hover:bg-white/[0.04] transition-all">
              <div class="flex items-center gap-3 mb-3 flex-wrap">
                <span class="eyebrow text-accent-glow">{categoryLabel[p.data.category]}</span>
                <span class="text-ink-600">·</span>
                <span class="text-xs font-mono uppercase tracking-widest text-ink-500">{formatDate(p.data.publishedAt)}</span>
              </div>
              <h2 class="font-serif text-2xl md:text-3xl text-paper-50 mb-3 leading-tight">{p.data.title}</h2>
              <p class="text-sm text-paper-300 leading-relaxed max-w-prose">{p.data.description}</p>
            </a>
          </li>
        ))}
      </ul>

      {posts.length === 0 && (
        <p class="mt-10 text-sm text-ink-500 italic max-w-prose">
          아직 한국어 게시물이 없습니다. 영어 원본은 <a href="/blog" class="text-accent-glow underline">/blog</a>에 있습니다.
        </p>
      )}
    </div>
  </section>

  <section class="py-16 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow text-center">
      <p class="text-sm text-ink-500 mb-4 max-w-xl mx-auto">
        대략 2주마다 새로운 게시물. 가장 중요한 것을 위한 월간 뉴스레터.
      </p>
      <a href="/ko/contact" class="btn-secondary">뉴스레터 구독 곧</a>
    </div>
  </section>
</BaseLayout>
