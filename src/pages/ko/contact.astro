---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { SITE } from "@/lib/site";

const channels = [
  {
    label: "일반",
    email: SITE.company.contactEmail,
    body: "피드백, 질문, 요청. 여기 들어오는 모든 것을 읽습니다.",
  },
  {
    label: "기관 및 영업",
    email: SITE.company.contactEmail,
    body: "대학, 학교, 연구실. DPA, 가격 브리프, 파일럿 프로그램 세부 정보를 보내드립니다.",
  },
  {
    label: "프레스",
    email: SITE.company.contactEmail,
    body: "인터뷰, 인용, 엠바고. 요청 시 로고와 스크린샷이 포함된 프레스 키트.",
  },
  {
    label: "보안",
    email: SITE.company.securityEmail,
    body: "취약점 보고. 24시간 이내 회신, 중요 사례 72시간 이내 패치.",
  },
  {
    label: "개인정보 및 데이터 요청",
    email: SITE.company.privacyEmail,
    body: "데이터 액세스, 내보내기, 삭제 (GDPR). 30일 이내 응답 — 일반적으로 48시간 이내.",
  },
  {
    label: "지원",
    email: SITE.company.supportEmail,
    body: "버그를 발견했거나 기능 사용에 도움이 필요한 사용자를 위해.",
  },
];
---

<BaseLayout
  title="문의"
  description="Fluera에 연락하세요. 일반, 영업, 프레스, 보안, 개인정보 및 지원을 위한 채널."
  locale="ko"
>
  <PageHero
    kicker="문의"
    title="6개 채널. 하나의 응답."
    description="티켓 시스템 없음. 아래의 모든 채널은 실제 사람에게 도착합니다 — 일반적으로 1-2일 이내에 응답합니다."
  >
    <div class="mt-16 grid md:grid-cols-2 gap-5 max-w-5xl">
      {channels.map((c) => (
        <article class="card p-6">
          <p class="eyebrow text-accent-glow mb-3">{c.label}</p>
          <a href={`mailto:${c.email}`} class="font-serif text-xl text-paper-50 block mb-3 hover:text-accent-glow transition-colors">
            {c.email}
          </a>
          <p class="text-sm text-paper-300 leading-relaxed">{c.body}</p>
        </article>
      ))}
    </div>
  </PageHero>

  <section class="py-16 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow text-center">
      <p class="text-sm text-ink-500 max-w-xl mx-auto leading-relaxed">
        본사는 {SITE.company.city}. 전화번호는 게시하지 않습니다: 서면 커뮤니케이션은 추적 가능하고 우리를 집중하게 합니다. 긴급한 보안 문제의 경우, PGP 키는 GitHub 프로필에 있습니다.
      </p>
    </div>
  </section>
</BaseLayout>
