---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { SITE } from "@/lib/site";

const pillars = [
  {
    title: "암호화",
    body: "모든 Fluera 노트북은 SQLCipher를 통해 AES-256으로 정지 시 암호화됩니다. 트래픽은 전송 중 TLS 1.3입니다. 기기 간 동기화는 패스프레이즈에서 파생된 키로 종단 간 암호화되며 — 플랫폼 키체인에 보관되고, 우리 서버로 전송되지 않습니다.",
  },
  {
    title: "데이터 소유권",
    body: "당신이 쓴 모든 바이트는 한 번 클릭으로 내보낼 수 있습니다: PNG, JPEG, WebP, SVG, PDF, 오픈 .fluera 형식. 노트북은 먼저 기기에 살고 있습니다. 클라우드는 편의이지 감옥이 아닙니다 — 락인은 우리가 거부한 비즈니스 모델입니다.",
  },
  {
    title: "GDPR 기본",
    body: "Fluera는 EU 호스팅이며 GDPR 원칙에 따라 설계되었습니다. 어떤 교육 기관이라도 요청 시 Data Processing Agreement를 사용할 수 있습니다. 완전한 데이터 내보내기 및 잊혀질 권리 요청은 30일 이내 (일반적으로 48시간 이내) 처리됩니다.",
  },
  {
    title: "로컬 우선, 항상",
    body: "Fluera를 완전히 오프라인으로 실행할 수 있습니다. 동기화는 노트북별 옵트인이며, 계정 전체가 아닙니다. 동기화를 끄면 데이터가 기기를 떠나지 않습니다 — 동의 기반이고 익명인 텔레메트리 포함.",
  },
  {
    title: "감사 로그 (기관)",
    body: "교육 계정의 경우, 공유 노트북에 대한 모든 액세스가 변경 불가능한 감사 추적에 기록되며, 컴플라이언스 검토를 위해 내보낼 수 있습니다. 관리자는 SSO (SAML, OIDC) 및 MDM 관리 배포를 강제할 수 있습니다.",
  },
  {
    title: "우리가 하지 않는 것",
    body: "광고 없음. 데이터 판매 없음. 우리 모델을 당신의 콘텐츠로 훈련하지 않음. 웹 전반에 걸쳐 추적하지 않음. 명명된 하위 처리자 (Supabase, Vercel, Stripe) 외에는 제3자에게 데이터를 전달하지 않음 — 모두 DPA 하에.",
  },
];
---

<BaseLayout
  title="보안 및 개인정보"
  description="정지 시 AES-256 암호화, GDPR 기본, EU 호스팅, 광고 기술 제로. Fluera의 보안 아키텍처와 데이터 소유권 약속을 읽으세요."
  locale="ko"
>
  <PageHero
    kicker="보안 및 개인정보"
    title="종단 간 암호화.<br />키는 당신이 쥡니다."
    titleSize="2xl"
    description="기본 암호화. 광고 기술 없음. EU 호스팅. 완전한 내보내기. 개인정보는 컴플라이언스 작업이 아닌 디자인 제약입니다."
    orbs
    noise
  />

  <section class="py-20 md:py-28">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-6 max-w-5xl">
        {pillars.map((p, i) => (
          <article class="card p-8">
            <div class="eyebrow text-accent-glow mb-4">{String(i + 1).padStart(2, "0")}</div>
            <h2 class="font-serif text-xl text-paper-50 mb-3">{p.title}</h2>
            <p class="text-sm text-paper-200 leading-relaxed">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-12 max-w-5xl">
        <div>
          <p class="eyebrow mb-4 text-accent-glow">책임 있는 공개</p>
          <h2 class="font-serif text-display-lg text-paper-50 mb-4">무언가를 발견했습니까?</h2>
          <p class="prose-ink mb-6">
            보안 연구원은 환영합니다. 취약점을
            <a href={`mailto:${SITE.company.securityEmail}`}>{SITE.company.securityEmail}</a>
            로 보고하세요. 24시간 이내 회신, 중요 문제 72시간 이내 패치, 익명을 선호하지 않는 한 명예의 전당에 보고자 인정.
          </p>
          <p class="text-sm text-ink-500 italic">
            암호화된 제출을 위한 PGP 키는 우리 GitHub에 게시되어 있습니다.
          </p>
        </div>
        <div>
          <p class="eyebrow mb-4 text-accent-glow">컴플라이언스 및 배포</p>
          <h2 class="font-serif text-display-lg text-paper-50 mb-4">기관에 Fluera를 배포하나요?</h2>
          <p class="prose-ink mb-6">
            대학, 학교, 연구실: DPA, 하위 처리자 목록, SSO 설정 및 감사 로그 모델을 안내해 드립니다. 파일럿은 일반적으로 한 클래스, 한 학기, 무료로 시작합니다.
          </p>
          <a href="/ko/contact" class="btn-primary">배포에 대해 상담 →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 border-t border-white/[0.04]">
    <div class="container-narrow text-center">
      <p class="text-xs text-ink-500 max-w-xl mx-auto leading-relaxed">
        이 페이지는 핵심 사항을 다룹니다. 전체 아키텍처, 하위 처리자 등록 및 DPA 템플릿은
        <a href="/ko/security/architecture" class="text-paper-300 underline">/ko/security/architecture</a> 및
        <a href="/ko/security/sub-processors" class="text-paper-300 underline">/ko/security/sub-processors</a>에 있습니다. 특정 컴플라이언스 질문이 있나요?
        <a href={`mailto:${SITE.company.securityEmail}`} class="text-paper-300 underline">{SITE.company.securityEmail}</a>로 작성하세요.
      </p>
    </div>
  </section>
</BaseLayout>
