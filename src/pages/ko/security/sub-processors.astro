---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { SITE } from "@/lib/site";

const processors = [
  {
    name: "Supabase Inc.",
    purpose: "데이터베이스, 인증, 암호화된 클라우드 스토리지, 실시간 시그널링, AI 프록시용 Edge Function.",
    dataTypes: "계정 이메일, 해시된 사용자 ID, 캔버스 암호문 (E2E 암호화), 동기화 메타데이터.",
    region: "프랑크푸르트, EU (Fluera 인스턴스의 기본 지역).",
    privacy: "https://supabase.com/privacy",
  },
  {
    name: "Google LLC",
    purpose: "Socratic Mode, Ghost Map, LaTeX OCR 및 Exam Session 생성을 위한 Google Generative AI (Gemini).",
    dataTypes: "선택된 캔버스 텍스트 부분 (AI 기능이 허용되고 활성화된 경우에만). 전체 노트북은 절대 아님.",
    region: "Google Cloud 지역을 통한 미국, EU; SCC + EU-US DPF.",
    privacy: "https://policies.google.com/privacy",
  },
  {
    name: "Apple Inc.",
    purpose: "Sign in with Apple 인증; iOS와 macOS의 App Store를 통한 인앱 구매.",
    dataTypes: "Apple ID 릴레이 이메일, 영수증 식별자. 캔버스 데이터 없음.",
    region: "미국; SCC + EU-US DPF.",
    privacy: "https://www.apple.com/legal/privacy/",
  },
  {
    name: "RevenueCat Inc.",
    purpose: "iOS, Android 및 웹의 구독 관리 및 영수증 검증.",
    dataTypes: "익명화된 RevenueCat 사용자 ID, 구독 상태, 영수증 메타데이터. 결제 카드 데이터 없음.",
    region: "미국; SCC + EU-US DPF.",
    privacy: "https://www.revenuecat.com/privacy",
  },
  {
    name: "Functional Software Inc. (Sentry)",
    purpose: "충돌 보고 및 오류 모니터링.",
    dataTypes: "스택 트레이스, OS 버전, 기기 모델, 앱 버전. sendDefaultPii는 명시적으로 비활성화 — 사용자 콘텐츠 없음.",
    region: "미국, EU 옵션 사용 가능.",
    privacy: "https://sentry.io/privacy/",
  },
  {
    name: "Vercel Inc.",
    purpose: "마케팅 사이트 fluera.dev 및 /docs 호스팅.",
    dataTypes: "표준 웹 액세스 로그 (IP, 사용자 에이전트). 계정 콘텐츠 없음.",
    region: "글로벌 엣지; 구성 가능한 원본 지역.",
    privacy: "https://vercel.com/legal/privacy-policy",
  },
];

const lastUpdated = "2026-04-20";
---

<BaseLayout
  title="하위 처리자"
  description="Fluera가 제품을 제공하기 위해 의지하는 제3자. 각 하위 처리자의 목적, 공유 데이터, 지역 및 개인정보 정책 링크."
  locale="ko"
>
  <PageHero
    kicker="하위 처리자"
    title="우리가 의지하는 모든 제3자."
    description="GDPR 28조에 따라, 우리를 대신해 개인 데이터를 처리하는 모든 하위 처리자가 여기에 나열됩니다 — 공유하는 것, 이유, 살고 있는 곳. 모든 변경 전에 고객에게 알립니다."
    breadcrumb={{ label: "보안", href: "/ko/security" }}
  >
    <p slot="copy" class="mt-6 text-sm text-ink-500 font-mono">최종 업데이트: {lastUpdated}</p>
  </PageHero>

  <section class="py-12 md:py-16">
    <div class="container-site">
      <ul class="space-y-4 list-none p-0 max-w-5xl">
        {processors.map((p) => (
          <li class="card p-6 md:p-7">
            <div class="grid md:grid-cols-4 gap-6">
              <div class="md:col-span-1">
                <h2 class="font-serif text-xl text-paper-50 mb-2">{p.name}</h2>
                <a href={p.privacy} class="text-xs text-accent-glow underline underline-offset-4 font-mono" rel="noopener">
                  개인정보 정책 ↗
                </a>
              </div>
              <dl class="md:col-span-3 grid gap-3 text-sm">
                <div>
                  <dt class="eyebrow text-ink-500 mb-1">목적</dt>
                  <dd class="text-paper-200">{p.purpose}</dd>
                </div>
                <div>
                  <dt class="eyebrow text-ink-500 mb-1">공유 데이터</dt>
                  <dd class="text-paper-200">{p.dataTypes}</dd>
                </div>
                <div>
                  <dt class="eyebrow text-ink-500 mb-1">지역</dt>
                  <dd class="text-paper-200">{p.region}</dd>
                </div>
              </dl>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-16 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow">
      <h2 class="font-serif text-xl text-paper-50 mb-4">변경 및 알림</h2>
      <p class="prose-ink text-sm mb-4">
        하위 처리자가 추가, 변경 또는 제거될 때마다 이 목록을 업데이트합니다. 기관 및 엔터프라이즈 고객은 GDPR 28(2)조에 따라 변경 최소 30일 전에 이메일 알림을 받습니다.
      </p>
      <p class="prose-ink text-sm">
        하위 처리자 변경 알림을 구독하려면 계정 주소에서 <a href={`mailto:${SITE.company.privacyEmail}`}>{SITE.company.privacyEmail}</a>로 작성하세요.
      </p>
    </div>
  </section>
</BaseLayout>
