---
import BaseLayout from "@/layouts/BaseLayout.astro";

const useCases = [
  {
    title: "강의 캡처",
    body: "학생들은 Time Travel을 통한 선택적 오디오 동기화로 강의 중 무한 캔버스에 손으로 노트를 작성합니다. 캔버스는 학기를 넘어 살아있는 아카이브가 됩니다.",
  },
  {
    title: "규모에 맞는 시험 준비",
    body: "Fog of War + 간격 반복은 학생의 개인 캔버스를 회상 연습 엔진으로 변환합니다. 교수는 콘텐츠를 지정하지 않고 주제별 학습 경로를 권장할 수 있습니다.",
  },
  {
    title: "STEM 실험실 노트북",
    body: "LaTeX 렌더링, 압력 감지 다이어그램, 동기화된 오디오로 실험 로그. 평가에 필요한 손글씨 증거를 보존하면서 종이 노트북을 대체합니다.",
  },
];

const deployment = [
  { label: "SSO",              body: "SAML 2.0과 OIDC. Shibboleth, Azure AD, Okta, Google Workspace for Education와 통합." },
  { label: "MDM 친화적",        body: "App Store / Play를 통한 표준 엔터프라이즈 배포. Windows와 macOS에 서명된 설치 프로그램. 사이드로딩 없음." },
  { label: "감사 로그",          body: "계정당 변경 불가능한 액세스 추적. 컴플라이언스 감사를 위해 내보낼 수 있음." },
  { label: "데이터 거주",        body: "기본적으로 EU의 서버. 요청 시 Data Processing Agreement 사용 가능." },
  { label: "접근성",             body: "모든 플랫폼에서 WCAG 2.1 AA 목표. 스크린 리더 지원, 고대비 모드, 운동 능력 차이를 위한 조정 가능한 브러시 충실도." },
  { label: "온프레미스",         body: "엔터프라이즈 로드맵에 곧. 오늘: 강력한 암호화 및 지역 제어가 있는 클라우드 전용." },
];
---

<BaseLayout
  title="대학을 위한 Fluera — 고등 교육을 위한 인지 인프라"
  description="당신의 학부에 증거 기반 학습 도구를 가져오세요. 멀티 시트 라이선스, SSO, 감사 로그, 12단계 사이클에 대한 교수 교육. 파일럿 프로그램 사용 가능."
  locale="ko"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04] relative overflow-hidden noise">
    <div class="glow-orb h-[500px] w-[500px] -top-32 -start-32 bg-accent-ink/25 animate-orb-pulse"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6 text-accent-glow">대학 및 학교</p>
        <h1 class="font-serif text-display-2xl text-paper-50 mb-6">
          현대 대학을 위한<br />인지 인프라.
        </h1>
        <p class="prose-ink text-xl max-w-2xl mb-10">
          학생들을 위한 증거 기반 학습 도구. IT를 위한 SSO. 학습의 인지 과학에 대한 교수 교육. 파일럿은 한 클래스, 한 학기, 무료로 시작합니다.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/ko/contact" class="btn-primary">학술 통화 예약 →</a>
          <a href="/ko/" class="btn-secondary">기반 과학</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">교수들이 Fluera를 선택하는 이유</p>
        <h2 class="font-serif text-display-xl text-paper-50">세 가지 구체적 패턴.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {useCases.map((u, i) => (
          <article class="card p-7">
            <div class="eyebrow text-accent-glow mb-4">{String(i + 1).padStart(2, "0")}</div>
            <h3 class="font-serif text-xl text-paper-50 mb-3">{u.title}</h3>
            <p class="text-sm text-paper-300 leading-relaxed">{u.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow mb-6 text-accent-glow">라이선스 모델</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-4">세 가지 레벨. 한 통의 전화로 충분합니다.</h2>
        <p class="prose-ink text-lg max-w-prose">
          기관 계정에 대한 시트당 가격을 게시하지 않습니다: 올바른 구조는 라이선스를 부여하려는 범위에 달려 있습니다 — 클래스, 학부 또는 대학. 한 번의 통화로 구체적인 가설을 가지고 나옵니다.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-4 max-w-5xl">
        <article class="card p-7">
          <h3 class="font-serif text-xl text-paper-50 mb-3">클래스</h3>
          <p class="text-sm text-paper-300 mb-4 leading-relaxed">
            한 강좌, 한 학기, 최대 200명 학생. 각 학생을 위한 Pro 액세스, 교수 대시보드, 한 번의 교육 세션.
          </p>
          <p class="text-xs font-mono uppercase tracking-widest text-ink-500">일반적 채택: 파일럿</p>
        </article>
        <article class="card p-7 border-accent-ink/40 bg-accent-ink/[0.05]">
          <h3 class="font-serif text-xl text-paper-50 mb-3">학부</h3>
          <p class="text-sm text-paper-300 mb-4 leading-relaxed">
            전체 학부. 다년 계약. SSO, 감사 로그, 전담 지원 SLA. 가입한 모든 강좌에 대한 교수 교육.
          </p>
          <p class="text-xs font-mono uppercase tracking-widest text-accent-glow">일반적 채택: 두 번째 해</p>
        </article>
        <article class="card p-7">
          <h3 class="font-serif text-xl text-paper-50 mb-3">대학</h3>
          <p class="text-sm text-paper-300 mb-4 leading-relaxed">
            전체 캠퍼스. 전담 배포 지원, 명명된 엔지니어링 연락처, 12단계 사이클에 대한 공동 연구 기회.
          </p>
          <p class="text-xs font-mono uppercase tracking-widest text-ink-500">일반적 채택: 세 번째 해부터</p>
        </article>
      </div>

      <div class="mt-10">
        <a href="/ko/contact" class="btn-primary">가격 브리프 요청 →</a>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <p class="eyebrow mb-6 text-accent-glow">교수 교육</p>
          <h2 class="font-serif text-display-lg text-paper-50 mb-6">두 시간. 인지 과학, 응용.</h2>
          <p class="prose-ink mb-4">
            워크숍은 12단계 학습 사이클, 각 단계 뒤의 원리, 기존 강좌에 Fluera를 통합하기 위한 구체적인 패턴을 다룹니다. 제품 데모가 아닙니다.
          </p>
          <p class="prose-ink">
            대면 또는 원격으로 제공, 세션당 최대 15명 참여, 그래서 모든 교수는 자신의 강좌를 위한 구체적인 계획을 가지고 나옵니다.
          </p>
        </div>
        <div class="card p-7">
          <h3 class="eyebrow text-accent-glow mb-4">우리가 다루는 것</h3>
          <ul class="space-y-3 text-sm text-paper-200 list-none p-0">
            <li class="flex gap-3"><span class="text-ink-500 font-mono">01</span><span>간격, 회상, 생성, 바람직한 어려움 — 네 기둥</span></li>
            <li class="flex gap-3"><span class="text-ink-500 font-mono">02</span><span>강좌 구조에 매핑된 12단계 사이클</span></li>
            <li class="flex gap-3"><span class="text-ink-500 font-mono">03</span><span>Socratic 사용 시기, Ghost Map 사용 시기, 길에서 비킬 시기</span></li>
            <li class="flex gap-3"><span class="text-ink-500 font-mono">04</span><span>평가를 대체하지 않고 Fog of War로 시험 준비 설계</span></li>
            <li class="flex gap-3"><span class="text-ink-500 font-mono">05</span><span>연구, 증거의 강도, 증거가 지원하는 것의 한계</span></li>
            <li class="flex gap-3"><span class="text-ink-500 font-mono">06</span><span>실습: 각 교수는 떠나기 전에 Fluera에서 강의를 구축합니다</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow mb-6 text-accent-glow">배포</p>
        <h2 class="font-serif text-display-xl text-paper-50">IT도 우리를 사랑할 것입니다.</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
        {deployment.map((d) => (
          <article class="card p-6">
            <h3 class="font-serif text-base font-medium text-paper-50 mb-2">{d.label}</h3>
            <p class="text-sm text-paper-300 leading-relaxed">{d.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="eyebrow mb-6 text-accent-glow">파일럿 프로그램</p>
          <h2 class="font-serif text-display-lg text-paper-50 mb-6">한 클래스. 한 학기. 무료.</h2>
          <p class="prose-ink mb-4">
            Fluera가 학생들에게 작동하는지 이해하는 가장 빠른 방법은 30명의 학생, 한 학기, 비용 없이 시도하는 것입니다. 그 대가로 구조화된 피드백을 요청합니다 — 중간 체크인, 학기 말 설문, 익명화된 결과 데이터를 공유할 옵션.
          </p>
          <p class="prose-ink">
            작동하면, 다년 계약에 대해 이야기합니다. 작동하지 않으면, 당신은 데이터를 가지고 우리는 교훈을 얻습니다. 어느 경우든, 우리 둘 다 얻습니다.
          </p>
        </div>
        <div class="card p-8 bg-accent-ink/[0.08] border-accent-ink/30">
          <h3 class="eyebrow text-accent-glow mb-4">받는 것</h3>
          <ul class="space-y-3 text-sm text-paper-200 list-none p-0 mb-6">
            <li class="flex items-start gap-3"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent-glow shrink-0"></span><span>최대 30명 학생을 위한 Pro 액세스</span></li>
            <li class="flex items-start gap-3"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent-glow shrink-0"></span><span>2시간 교수 워크숍</span></li>
            <li class="flex items-start gap-3"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent-glow shrink-0"></span><span>학기 동안 창립자와의 직접 채널</span></li>
            <li class="flex items-start gap-3"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-accent-glow shrink-0"></span><span>보고를 위한 익명화된 집계 분석</span></li>
          </ul>
          <a href="/ko/contact" class="btn-primary w-full">파일럿 시작 →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-ink-900/40">
    <div class="container-narrow text-center">
      <h2 class="font-serif text-display-lg text-paper-50 mb-4">GDPR 기본. FERPA 인식. WCAG 2.1 AA 목표.</h2>
      <p class="prose-ink mb-8 max-w-2xl mx-auto">
        세부 사항은 보안 페이지에 있습니다 — 하위 처리자 목록, Data Processing Agreement, 암호화 아키텍처, 감사 로그 모델.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/ko/security" class="btn-secondary">보안 아키텍처 읽기 →</a>
        <a href="/ko/contact" class="btn-primary">상담</a>
      </div>
    </div>
  </section>

</BaseLayout>
