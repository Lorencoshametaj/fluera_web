---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// No Korean MDX files yet — use EN as fallback content. URLs still route
// to /ko/features/{slug} which Astro rewrites to /features/{slug} (EN).
const features = (await getCollection("features", ({ data }) => data.lang === "en")).sort(
  (a, b) => a.data.order - b.data.order,
);

const statusLabel: Record<string, string> = {
  stable: "이용 가능",
  beta: "베타",
  "coming-soon": "곧 출시",
};

const statusStyle: Record<string, string> = {
  stable:        "text-signal-ok border-signal-ok/30",
  beta:          "text-accent-glow border-accent-glow/30",
  "coming-soon": "text-signal-warn border-signal-warn/30",
};
---

<BaseLayout
  title="기능"
  description="Ghost Map, Atlas, Socratic Mode, Fog of War, Cross-Zone Bridges, Exam Session, Reflow, 간격 반복. 모든 기능이 인용된 원리에 거슬러 올라갑니다."
  locale="ko"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04] relative overflow-hidden noise">
    <div class="glow-orb h-[420px] w-[420px] -top-40 -end-32 bg-accent-glow/20 animate-orb-pulse"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6 text-accent-glow">기능</p>
        <h1 class="font-serif text-display-2xl text-paper-50 mb-6">
          기억이 구축되는<br />여덟 가지 방법.
        </h1>
        <p class="prose-ink text-xl max-w-2xl">
          각 기능은 12단계 학습 사이클의 특정 단계에 위치합니다. 각 기능은 사이언스 페이지의 하나 이상의 원리에 거슬러 올라갑니다. 모든 기능은 인용으로 자신을 변호합니다.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 border-b border-white/[0.04]">
    <div class="container-site">
      <ul class="space-y-6 list-none p-0 max-w-5xl">
        {features.map((f) => (
          <li>
            <a href={`/ko/features/${f.id}`} class="block card p-8 md:p-10 hover:border-accent-glow/40 hover:bg-white/[0.04] transition-all">
              <div class="grid md:grid-cols-3 gap-8 items-start">
                <div class="md:col-span-2">
                  <div class="flex items-center gap-3 mb-4 flex-wrap">
                    {f.data.stepInCycle && (
                      <span class="eyebrow text-accent-glow">{f.data.stepInCycle}단계</span>
                    )}
                    <span class={`pill text-[10px] capitalize ${statusStyle[f.data.status]}`}>
                      {statusLabel[f.data.status]}
                    </span>
                  </div>
                  <h2 class="font-serif text-display-lg text-paper-50 mb-4">{f.data.title}</h2>
                  <p class="prose-ink text-lg mb-4 max-w-prose">{f.data.tagline}</p>
                  <p class="text-sm text-paper-300 max-w-prose">{f.data.shortDescription}</p>
                </div>
                <div class="flex md:justify-end items-start">
                  <span class="text-accent-glow text-sm font-mono uppercase tracking-widest">자세히 보기 →</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-20 bg-ink-900/40">
    <div class="container-narrow text-center">
      <h2 class="font-serif text-display-lg text-paper-50 mb-4">베타에서 모두 시도하세요.</h2>
      <p class="prose-ink mb-8 max-w-2xl mx-auto">
        기능은 먼저 iOS와 macOS에 도착하고, 다음에 Android와 데스크톱이 옵니다. 비공개 베타에 참여하고 조기 액세스를 원하는 플랫폼을 선택하세요.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/beta" class="btn-primary">액세스 요청 →</a>
        <a href="/ko/" class="btn-secondary">홈으로 돌아가기</a>
      </div>
    </div>
  </section>

</BaseLayout>
