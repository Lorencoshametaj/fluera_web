---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { authorSeo } from "@/lib/seo-templates";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const authors = await getCollection("authors", ({ data }) => data.lang === "sv");
  return authors.map((a) => ({
    params: { slug: a.id.replace(/\.sv$/, "") },
    props: { author: a },
  }));
}

const { author } = Astro.props;
// SEO: JSON-LD schema + hreflang alternates (multi-locale aware).
const allAuthors = await getCollection("authors", () => true);
const seo = authorSeo({ author, allAuthors, pathname: Astro.url.pathname });
const { Content } = await render(author);

async function resolveLocalized<T extends "principles" | "features">(
  collection: T,
  ref: { id: string },
) {
  const localizedId = ref.id.endsWith(".sv") ? ref.id : `${ref.id}.sv`;
  return (await getEntry(collection, localizedId)) ?? (await getEntry(collection, ref.id));
}

const principles = (
  await Promise.all(author.data.keyPrinciples.map((r) => resolveLocalized("principles", r)))
).filter(Boolean);
const features = (
  await Promise.all(author.data.appliedInFeatures.map((r) => resolveLocalized("features", r)))
).filter(Boolean);

const statusLabel: Record<string, string> = {
  stable: "Tillgänglig",
  beta: "I beta",
  "coming-soon": "Snart",
};
---

<BaseLayout
  jsonLd={seo.jsonLd}
  alternates={seo.alternates}
  ogImage={seo.ogImage}
  title={`${author.data.name} — Vetenskapen bakom Fluera`}
  description={author.data.shortBio}
  locale="sv"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-prose">
      <nav class="mb-8 text-xs font-mono uppercase tracking-widest text-ink-500" aria-label="Breadcrumb">
        <a href="/sv/science" class="hover:text-paper-200">Vetenskap</a>
        <span class="mx-2 text-ink-600">/</span>
        <a href="/sv/science#authors" class="hover:text-paper-200">Forskare</a>
      </nav>

      <div class="flex items-start justify-between gap-4 mb-6">
        <p class="eyebrow text-accent-glow">{author.data.fields.join(" · ")}</p>
        {author.data.nobelLaureate && <span class="pill text-[11px] text-accent-glow border-accent-glow/30">Nobelpris</span>}
      </div>

      <h1 class="font-serif text-display-xl text-paper-50 mb-4">{author.data.name}</h1>
      <p class="font-mono text-sm text-ink-500 uppercase tracking-widest mb-6">{author.data.years}</p>
      <p class="prose-ink text-xl mb-8">{author.data.shortBio}</p>

      <dl class="py-6 border-t border-white/[0.06]">
        <dt class="eyebrow mb-2 text-ink-500">Referensverk</dt>
        <dd class="font-serif text-paper-100 text-base italic">{author.data.notableWork}</dd>
      </dl>

      {author.data.externalProfile && (
        <a href={author.data.externalProfile} class="btn-secondary text-sm mt-2" rel="noopener">
          Akademisk profil ↗
        </a>
      )}
    </div>
  </section>

  <article class="py-16 md:py-20 border-b border-white/[0.04]">
    <div class="container-prose prose-v2">
      <Content />
    </div>
  </article>

  {principles.length > 0 && (
    <section class="py-16 md:py-20 border-b border-white/[0.04] bg-ink-900/40">
      <div class="container-prose">
        <p class="eyebrow mb-6 text-accent-glow">Relaterade principer</p>
        <h2 class="font-serif text-2xl text-paper-50 mb-6">Idéerna som deras arbete har bidragit till.</h2>
        <ul class="grid sm:grid-cols-2 gap-3 list-none p-0">
          {principles.map((p) => p && (
            <li>
              <a href={`/sv/science/principles/${p.id.replace(/\.sv$/, "")}`} class="block card p-5 hover:border-accent-glow/40 transition-colors">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="font-serif text-base font-medium text-paper-50">{p.data.title}</h3>
                  <span class="text-[10px] font-mono uppercase tracking-widest text-ink-500">{p.data.keyYear}</span>
                </div>
                <p class="text-sm text-paper-300 line-clamp-2">{p.data.shortDescription}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {features.length > 0 && (
    <section class="py-16 border-b border-white/[0.04]">
      <div class="container-prose">
        <p class="eyebrow mb-6 text-accent-glow">Tillämpat i Fluera</p>
        <h2 class="font-serif text-2xl text-paper-50 mb-6">Funktioner som bygger på detta arbete.</h2>
        <ul class="space-y-3 list-none p-0">
          {features.map((f) => f && (
            <li>
              <a href={`/sv/features/${f.id.replace(/\.sv$/, "")}`} class="block card p-5 hover:border-accent-glow/40 transition-colors">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="font-serif text-lg text-paper-50">{f.data.title}</h3>
                  <span class="pill text-[10px]">{statusLabel[f.data.status]}</span>
                </div>
                <p class="text-sm text-paper-300">{f.data.tagline}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="py-16 bg-ink-900/40">
    <div class="container-narrow text-center">
      <a href="/sv/science" class="btn-secondary">← Tillbaka till vetenskapen</a>
    </div>
  </section>

</BaseLayout>
