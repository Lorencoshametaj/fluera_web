---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorCard from "@/components/AuthorCard.astro";
import LearningStep from "@/components/LearningStep.astro";
import PillarFeature from "@/components/PillarFeature.astro";
import NewsletterCapture from "@/components/NewsletterCapture.astro";
import { SITE, PRIMARY_CTA } from "@/lib/site";
import home from "@/data/home/en";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: SITE.name,
  applicationCategory: ["EducationalApplication", "ProductivityApplication"],
  operatingSystem: "iOS, Android, macOS, Windows, Linux, Web",
  description: SITE.description,
  url: SITE.url,
  audience: [
    { "@type": "EducationalAudience", educationalRole: "student" },
    { "@type": "Audience", audienceType: "knowledge worker" },
    { "@type": "EducationalAudience", educationalRole: "teacher" },
  ],
  offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
};

const { steps, authors, platforms, comparison, medicalUseCase } = home;
---

<BaseLayout
  title={SITE.name}
  description={SITE.description}
  jsonLd={jsonLd}
>

  <!-- ═══════════ 1 · HERO ═══════════ -->
  <section class="relative overflow-hidden noise">
    <div class="glow-orb h-[500px] w-[500px] -top-40 -start-40 bg-accent-ink/30 animate-orb-pulse"></div>
    <div class="glow-orb h-[420px] w-[420px] top-32 -end-20 bg-accent-glow/25 animate-orb-pulse" style="animation-delay: -3s"></div>

    <div class="container-site relative pt-24 md:pt-32 pb-20 md:pb-28">
      <div class="max-w-3xl">
        <div class="pill mb-8">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-glow animate-pulse"></span>
          Private beta · Early access by request
        </div>

        <h1 class="font-serif text-display-2xl text-paper-50 mb-6 animate-fade-up">
          The notebook that studies <span class="text-gradient">you back.</span>
        </h1>

        <p class="text-xl md:text-2xl text-paper-200 max-w-2xl leading-relaxed mb-10 animate-fade-up" style="animation-delay: 0.15s">
          Handwrite on an infinite canvas. Fluera turns it into a living map of your degree — then quizzes, questions, and re-tests you on your own notes. A learning canvas, not a note app.
        </p>

        <div class="flex flex-wrap items-center gap-4 mb-6 animate-fade-up" style="animation-delay: 0.3s">
          <a href={PRIMARY_CTA.href} class="btn-primary text-base px-6 py-3.5">
            {PRIMARY_CTA.label}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#how-it-works" class="btn-secondary text-base px-6 py-3.5">
            See how it works
          </a>
        </div>

        <p class="text-xs text-ink-500 mb-10 flex flex-wrap items-center gap-x-3 gap-y-1 animate-fade-up" style="animation-delay: 0.4s">
          <a href={SITE.social.github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:text-accent-glow transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8 0 3.2.9.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.3v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>
            Engine open source
          </a>
          <span class="text-ink-600">·</span>
          <span>Cancel anytime</span>
          <span class="text-ink-600">·</span>
          <span>No tracking</span>
        </p>

        <p class="text-sm text-ink-500 flex flex-wrap items-center gap-x-3 gap-y-1">
          <span>iOS</span><span class="text-ink-600">·</span>
          <span>Android</span><span class="text-ink-600">·</span>
          <span>macOS</span><span class="text-ink-600">·</span>
          <span>Windows</span><span class="text-ink-600">·</span>
          <span>Linux</span><span class="text-ink-600">·</span>
          <span>Web</span><span class="text-ink-600">·</span>
          <span>End-to-end encrypted</span><span class="text-ink-600">·</span>
          <span>GDPR-native</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════ 2 · HOW IT WORKS — product-first, the moat ═══════════ -->
  <section id="how-it-works" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">How it works</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          A canvas that <span class="text-gradient">understands</span> what you write.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Most note apps store ink. Fluera <em>reads</em> it — recognising your handwriting, grouping it by concept and discipline, then turning it into something you can manipulate and remember. One page: capture, understand, do, remember. No switching to a calculator, a flashcard app, or a chatbot.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="p-6 rounded-2xl border border-white/[0.06] bg-white/[0.02]">
          <p class="eyebrow text-accent-glow mb-3">01 · Capture</p>
          <h3 class="font-serif text-lg text-paper-50 mb-2">Handwrite anything</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Infinite canvas, 13 pressure-sensitive brushes, PDFs, and voice recorded in sync with your strokes — with live transcription. Notes, formulas, diagrams, in your own hand.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/[0.06] bg-white/[0.02]">
          <p class="eyebrow text-accent-glow mb-3">02 · Understand</p>
          <h3 class="font-serif text-lg text-paper-50 mb-2">It reads the page</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Fluera recognises what you wrote, clusters it by concept, and labels it by discipline. Every page joins your Atlas — a living map of meaning across your whole degree, which is what lets everything below actually work.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/[0.06] bg-white/[0.02]">
          <p class="eyebrow text-accent-glow mb-3">03 · Do</p>
          <h3 class="font-serif text-lg text-paper-50 mb-2">Your work comes alive</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Write <span class="font-mono">F = ma</span> by hand, drag the mass, watch the line bend. Get quizzed Socratically on what you wrote. The notebook stops being passive.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/[0.06] bg-white/[0.02]">
          <p class="eyebrow text-accent-glow mb-3">04 · Remember</p>
          <h3 class="font-serif text-lg text-paper-50 mb-2">It schedules what fades</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Spaced repetition (FSRS) brings back what you're about to forget, and your canvas follows you across every device. Learning that survives the week.</p>
        </div>
      </div>

      <p class="mt-10 text-sm text-paper-300 max-w-2xl leading-relaxed">
        The difference isn't a better graph or a smarter chatbot — it's that all of it happens <em>inside your own notes</em>, on what you actually wrote.
        <a href="/features/formula-to-graph" class="text-accent-glow hover:underline">See a formula come alive →</a>
      </p>
    </div>
  </section>

  <!-- ═══════════ 3 · PILLAR FEATURES (the product) ═══════════ -->
  <section id="pillar-features" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-20">
        <p class="eyebrow mb-6 text-accent-glow">Four cognitive differentiators</p>
        <h2 class="font-serif text-display-xl text-paper-50">
          Four ways memory gets built.
        </h2>
      </div>

      <div class="space-y-28">
        <PillarFeature
          label="Ghost Map · Step 4"
          title="See the gap between what you wrote and what was right."
          description="After you finish a problem, Fluera overlays your work against an ideal solution. The mismatches don't shame — they shock the memory awake. The wronger you were, the more the right answer sticks."
          citation="Hypercorrection effect — Butterfield & Metcalfe, 2001."
          href="/beta"
          status="beta"
        />
        <PillarFeature
          label="Socratic Mode · Step 3"
          title="Our AI doesn't answer. It asks."
          description="Rate your confidence one to five before each reveal. Metacognition is half of mastery, and confidence calibration is how you build it — one prediction at a time."
          citation="Metacognitive monitoring — Flavell, 1979."
          href="/beta"
          status="beta"
          reverse
        />
        <PillarFeature
          label="Fog of War · Step 10"
          title="Exam mode that hides what you almost remember."
          description="Mask any region of the canvas. Pull it back from memory before revealing. The retrieval struggle — not the seeing-again — is where memory hardens."
          citation="Desirable difficulties — Bjork, 1994."
          href="/beta"
          status="beta"
        />
        <PillarFeature
          label="Exam Session · Step 11"
          title="Simulated exams from your own canvas — graded by Ghost Map."
          description="Confidence picker one to five before each question. Closed-book. After you submit, Fluera overlays your answer against the ideal and applies hypercorrection where you were most overconfident. The bigger the surprise, the harder it sticks."
          citation="Hypercorrection — Butterfield & Metcalfe, 2001 · Productive failure — Kapur, 2008."
          href="/features/exam-session"
          status="beta"
          reverse
        />
      </div>

      <div class="mt-24 max-w-3xl">
        <a href="/beta" class="btn-primary">Try the four pillars →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ 4 · COMPARISON VS COMPETITOR ═══════════ -->
  <section id="comparison" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">{comparison.kicker}</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          {comparison.title}
        </h2>
        <p class="prose-ink text-lg max-w-prose">{comparison.sub}</p>
      </div>

      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-x-auto max-w-5xl">
        <table class="w-full text-sm min-w-[640px]">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="text-start font-mono uppercase tracking-widest text-xs text-ink-500 px-4 py-4 w-2/5">Capability</th>
              <th class="text-start font-serif text-base text-accent-glow px-4 py-4">{comparison.columns.fluera}</th>
              <th class="text-start font-serif text-base text-paper-200 px-4 py-4">{comparison.columns.goodNotes}</th>
              <th class="text-start font-serif text-base text-paper-200 px-4 py-4">{comparison.columns.notion}</th>
              <th class="text-start font-serif text-base text-paper-200 px-4 py-4">{comparison.columns.anki}</th>
            </tr>
          </thead>
          <tbody>
            {comparison.rows.map((r) => (
              <tr class="border-b border-white/[0.04] last:border-0">
                <td class="px-4 py-4 text-paper-200 font-medium align-top">{r.feature}</td>
                <td class="px-4 py-4 text-accent-glow align-top">{r.fluera}</td>
                <td class="px-4 py-4 text-ink-500 align-top">{r.goodNotes}</td>
                <td class="px-4 py-4 text-ink-500 align-top">{r.notion}</td>
                <td class="px-4 py-4 text-ink-500 align-top">{r.anki}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-xs text-ink-500 max-w-3xl italic">{comparison.footnote}</p>
    </div>
  </section>

  <!-- ═══════════ 5 · WHY HANDWRITING WINS ═══════════ -->
  <section id="handwriting" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="grid md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-5">
          <p class="eyebrow mb-6 text-accent-glow">Ink, not type</p>
          <h2 class="font-serif text-display-lg text-paper-50 mb-6">
            Type is faster.<br />Handwriting is better.<br />The brain isn't optimized for speed.
          </h2>
          <p class="text-sm text-ink-500 italic">Mueller & Oppenheimer, Princeton 2014 · van der Meer, NTNU 2020</p>
        </div>

        <div class="md:col-span-7 prose-ink text-lg">
          <p>
            When Mueller and Oppenheimer ran their now-famous Princeton study in 2014, they found that students who took notes by hand outperformed laptop-takers on conceptual questions — <em>even though</em> laptop-takers wrote significantly more words. The hand was slower. The mind was deeper.
          </p>
          <p>
            A decade later, Audrey van der Meer's EEG work at NTNU (2020) gave us the <em>why</em>: handwriting recruits broader brain networks than typing, especially in regions tied to memory formation and sensorimotor integration. The pen, it turns out, is a cognitive instrument.
          </p>
          <p>
            Fluera is built around this finding. Thirteen brush engines. Pressure, tilt, velocity. Sub-15-millisecond stroke latency on every supported device. The infinite canvas isn't an aesthetic — it's the substrate your memory has been asking for.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ · CANVAS & ENGINE (capabilities, first-class) ═══════════ -->
  <section id="engine" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Canvas & engine</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          A real engine under the ink.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Fluera isn't a wrapper around a text box. It's a GPU-native 2D engine — thirteen brushes, handwriting and formula recognition, PDF, voice, and real-time collaboration — the substrate everything cognitive is built on.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="card p-6">
          <h3 class="font-serif text-lg text-paper-50 mb-2">13 pressure brushes</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Ballpoint to watercolour — full rendering pipelines with pressure, tilt, velocity and per-brush shaders. Sub-15&nbsp;ms stroke latency.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-serif text-lg text-paper-50 mb-2">Handwriting & formula recognition</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Your ink becomes text and LaTeX — including handwritten maths, which Fluera understands well enough to turn into a live, interactive graph.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-serif text-lg text-paper-50 mb-2">Voice + live transcription</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Record audio in sync with your strokes, transcribed in real time — replay the lecture exactly where your pen was.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-serif text-lg text-paper-50 mb-2">PDF annotation</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Drop in slides, papers, textbooks. Annotate by hand on the same infinite canvas as everything else.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-serif text-lg text-paper-50 mb-2">Real-time collaboration</h3>
          <p class="text-sm text-paper-300 leading-relaxed">Share a canvas and think together, live — conflict-free multi-user editing (CRDT), so two pens never fight.</p>
        </div>
        <div class="card p-6">
          <h3 class="font-serif text-lg text-paper-50 mb-2">Export anywhere</h3>
          <p class="text-sm text-paper-300 leading-relaxed">PNG, JPEG, WebP, SVG, PDF, or the open <span class="font-mono">.fluera</span> format. Your notebook is yours to take.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ 6 · USE CASE: MEDICAL STUDENTS ═══════════ -->
  <section id="medical-students" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">{medicalUseCase.kicker}</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          {medicalUseCase.title}
        </h2>
        <p class="prose-ink text-lg max-w-prose">{medicalUseCase.intro}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-5xl">
        {medicalUseCase.steps.map((s) => (
          <div class="card p-6 md:p-7">
            <p class="eyebrow text-accent-glow mb-3">{s.phase}</p>
            <h3 class="font-serif text-xl text-paper-50 mb-3">{s.title}</h3>
            <p class="text-sm text-paper-300 leading-relaxed">{s.description}</p>
          </div>
        ))}
      </div>

      <p class="mt-10 prose-ink text-base max-w-3xl italic">{medicalUseCase.closing}</p>
    </div>
  </section>

  <!-- ═══════════ 7 · PROBLEM STATEMENT (why it matters) ═══════════ -->
  <section id="problem" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow">
      <p class="eyebrow mb-6 text-accent-glow">The bottleneck</p>
      <h2 class="font-serif text-display-xl text-paper-50 mb-8">
        You can ask any question.<br />You still can't remember the answer.
      </h2>
      <div class="prose-ink text-lg">
        <p>
          In 2026, knowledge takes three seconds to retrieve and three weeks to forget. We have ten apps for taking notes and none for keeping what we learn.
        </p>
        <p>
          Highlighting feels like studying. Re-reading feels like studying. Asking an LLM for a summary feels like studying. None of them are — and the cognitive science has been clear about this since the 1970s.
        </p>
        <p>
          The bottleneck of learning is no longer access — it's <em>encoding, retention, and transfer</em>: three problems at once.
        </p>
        <p class="font-serif text-paper-50 text-xl">
          Fluera is built for those three.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════ 8 · THE 12-STEP LEARNING CYCLE (the method) ═══════════ -->
  <section id="learning-cycle" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">The method</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          One canvas.<br />Twelve cognitive moves.<br />The loop your brain learns from.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Every Fluera feature lives at a step in this loop, and every step is grounded in published research. Skip one, the chain breaks. Keep them all, the notebook becomes permanent.
        </p>
      </div>

      <ol class="max-w-3xl list-none p-0">
        {steps.map((s) => (
          <LearningStep n={s.n} title={s.title} verb={s.verb} description={s.description} />
        ))}
      </ol>

      <div class="mt-12 max-w-3xl">
        <a href="/#science" class="btn-secondary">Explore the science →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ 9 · SCIENTIFIC FOUNDATION (credibility band) ═══════════ -->
  <section id="science" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Built on 50+ years of memory research</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          Standing on the shoulders of giants — by name.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Every design decision traces back to a paper we can link to. Twelve of those minds are below. The full bibliography lives in a public vault.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {authors.map((a) => (
          <AuthorCard name={a.name} contribution={a.contribution} year={a.year} nobel={a.nobel} />
        ))}
      </div>

      <div class="mt-12 p-6 rounded-2xl border border-white/[0.06] bg-white/[0.02] max-w-2xl">
        <h3 class="font-serif text-lg text-paper-50 mb-2">What we don't claim</h3>
        <p class="text-sm text-paper-300 leading-relaxed mb-3">
          We cite five decades of memory research. We have not run our own randomized trials on Fluera itself — not yet. When we say "evidence-based," we mean the underlying principles are; our specific implementation is an engineering bet informed by the evidence.
        </p>
        <p class="text-sm text-paper-300 leading-relaxed">
          We also don't promise expertise. Meta-analyses (Macnamara, Hambrick &amp; Moreau, 2014) found that deliberate practice accounts for roughly 4% of the variance in educational performance — the rest is prior knowledge, motivation, working memory capacity, and opportunity. Fluera optimizes the practice loop. The hours, the focus, and the curiosity are still yours.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════ 10 · MULTIPLATFORM PROOF ═══════════ -->
  <section id="platforms" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Six platforms, one ink</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          Six platforms. One ink. One brain.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Native renderers on Vulkan, Metal, OpenGL, Direct3D 11 and WebGPU. Your notebook syncs end-to-end encrypted, or stays offline. Your call.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-7 gap-3">
        {platforms.map((p) => (
          <div class="card p-5 flex flex-col items-start gap-2">
            <span class="eyebrow text-accent-glow">{p.status}</span>
            <h3 class="font-serif text-lg text-paper-50">{p.name}</h3>
            <p class="text-xs text-ink-500 font-mono">{p.api}</p>
          </div>
        ))}
      </div>

      <p class="mt-6 text-xs text-ink-500 max-w-2xl">
        Status labels are honest about release readiness. Platforms marked "Alpha" or "Demo" work but need polish — request early access if you want to help shape them.
      </p>
    </div>
  </section>

  <!-- ═══════════ 11 · SECURITY & PRIVACY ═══════════ -->
  <section id="security" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Your mind, your data</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          End-to-end encrypted.<br />You hold the key.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl">
        <div class="card p-6">
          <div class="eyebrow text-accent-glow mb-3">01</div>
          <h3 class="font-serif text-lg text-paper-50 mb-2">AES-256 at rest</h3>
