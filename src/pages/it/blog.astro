---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import NewsletterCapture from "@/components/NewsletterCapture.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft && data.lang === "it"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categoryLabel: Record<string, string> = {
  "cognitive-science": "Scienza cognitiva",
  "product": "Prodotto",
  "engineering": "Ingegneria",
  "field-notes": "Appunti sul campo",
};

function formatDate(d: Date) {
  return d.toLocaleDateString("it-IT", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
  title="Blog"
  description="Scienza cognitiva applicata. Note di prodotto. Dettagli di ingegneria. Le cose che valeva la pena scrivere."
  locale="it"
>
  <PageHero
    kicker="Blog"
    title="Scienza cognitiva, applicata."
    description="Note su cosa stiamo costruendo e perché. Niente listicle. Niente thought leadership. Abbastanza corto da leggerlo, abbastanza lungo da voler dire qualcosa."
  />

  <section class="py-12 md:py-16">
    <div class="container-site">
      <ul class="space-y-4 list-none p-0 max-w-4xl">
        {posts.map((p) => (
          <li>
            <a href={`/it/blog/${p.id.replace(/\.it$/, "")}`} class="block card p-6 md:p-8 hover:border-accent-glow/40 hover:bg-white/[0.04] transition-all">
              <div class="flex items-center gap-3 mb-3 flex-wrap">
                <span class="eyebrow text-accent-glow">{categoryLabel[p.data.category]}</span>
                <span class="text-ink-600">·</span>
                <span class="text-xs font-mono uppercase tracking-widest text-ink-500">{formatDate(p.data.publishedAt)}</span>
              </div>
              <h2 class="font-serif text-2xl md:text-3xl text-paper-50 mb-3 leading-tight">{p.data.title}</h2>
              <p class="text-sm text-paper-300 leading-relaxed max-w-prose">{p.data.description}</p>
            </a>
          </li>
        ))}
      </ul>

      {posts.length === 0 && (
        <p class="mt-10 text-sm text-ink-500 italic max-w-prose">
          Ancora nessun post in italiano. Gli originali sono su <a href="/blog" class="text-accent-glow underline">/blog</a>.
        </p>
      )}
    </div>
  </section>

  <section class="py-16 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow">
      <NewsletterCapture
        variant="card"
        headline="Un'email al mese. Solo le cose buone."
        sub="Nuovi post ogni circa due settimane. Per quelli che contano di più — deep dive di scienza cognitiva, decisioni di prodotto, note dietro le quinte — una newsletter mensile. Disiscriviti quando vuoi."
        buttonLabel="Iscriviti"
      />
    </div>
  </section>
</BaseLayout>
