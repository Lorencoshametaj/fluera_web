---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorCard from "@/components/AuthorCard.astro";
import LearningStep from "@/components/LearningStep.astro";
import PillarFeature from "@/components/PillarFeature.astro";
import NewsletterCapture from "@/components/NewsletterCapture.astro";
import { SITE } from "@/lib/site";
import home from "@/data/home/it";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: SITE.name,
  applicationCategory: ["EducationalApplication", "ProductivityApplication"],
  operatingSystem: "iOS, Android, macOS, Windows, Linux, Web",
  description: "Un canvas di studio infinito costruito sulla scienza cognitiva dell'apprendimento.",
  url: `${SITE.url}/it/`,
  audience: [
    { "@type": "EducationalAudience", educationalRole: "student" },
    { "@type": "Audience", audienceType: "knowledge worker" },
    { "@type": "EducationalAudience", educationalRole: "teacher" },
  ],
  offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
};

const { steps, authors, platforms, comparison, medicalUseCase } = home;
---

<BaseLayout
  title={SITE.name}
  description="Un canvas di studio infinito costruito sulla scienza cognitiva dell'apprendimento. iOS, Android, macOS, Windows, Linux, Web."
  jsonLd={jsonLd}
  locale="it"
>

  <!-- ═══════════ 1 · HERO ═══════════ -->
  <section class="relative overflow-hidden noise">
    <div class="glow-orb h-[500px] w-[500px] -top-40 -start-40 bg-accent-ink/30 animate-orb-pulse"></div>
    <div class="glow-orb h-[420px] w-[420px] top-32 -end-20 bg-accent-glow/25 animate-orb-pulse" style="animation-delay: -3s"></div>

    <div class="container-site relative pt-24 md:pt-32 pb-20 md:pb-28">
      <div class="max-w-3xl">
        <div class="pill mb-8">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-glow animate-pulse"></span>
          Beta privata · Accesso anticipato su richiesta
        </div>

        <h1 class="font-serif text-display-2xl text-paper-50 mb-6 animate-fade-up">
          Lo spazio di studio<br />costruito sul<br /><span class="text-gradient">funzionamento della mente.</span>
        </h1>

        <p class="text-xl md:text-2xl text-paper-200 max-w-2xl leading-relaxed mb-10 animate-fade-up" style="animation-delay: 0.15s">
          Scrivi a mano su un canvas infinito. Lascia che l'IA ti interroghi invece di darti risposte. Rivedi il tuo pensiero nel tempo. Calibrato sul modo in cui la memoria si forma davvero.
        </p>

        <div class="flex flex-wrap items-center gap-4 mb-6 animate-fade-up" style="animation-delay: 0.3s">
          <a href="/beta" class="btn-primary text-base px-6 py-3.5">
            Richiedi accesso anticipato
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/demo" class="btn-secondary text-base px-6 py-3.5">
            Prova la demo — senza registrazione
          </a>
        </div>

        <p class="text-xs text-ink-500 mb-10 flex flex-wrap items-center gap-x-3 gap-y-1 animate-fade-up" style="animation-delay: 0.4s">
          <a href={SITE.social.github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:text-accent-glow transition-colors">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8 0 3.2.9.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.3v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>
            Engine open source
          </a>
          <span class="text-ink-600">·</span>
          <span>Disdici quando vuoi</span>
          <span class="text-ink-600">·</span>
          <span>Zero tracking</span>
        </p>

        <p class="text-sm text-ink-500 flex flex-wrap items-center gap-x-3 gap-y-1">
          <span>iOS</span><span class="text-ink-600">·</span>
          <span>Android</span><span class="text-ink-600">·</span>
          <span>macOS</span><span class="text-ink-600">·</span>
          <span>Windows</span><span class="text-ink-600">·</span>
          <span>Linux</span><span class="text-ink-600">·</span>
          <span>Web</span><span class="text-ink-600">·</span>
          <span>End-to-end cifrato</span><span class="text-ink-600">·</span>
          <span>GDPR per default</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════ 2 · FONDAMENTI SCIENTIFICI (trust signal in alto) ═══════════ -->
  <section id="science" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Sopra 50+ anni di ricerca sulla memoria</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          Sulle spalle dei giganti — citati per nome.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Ogni scelta di design risale a un paper. Qui dodici delle menti che vivono dentro Fluera. La bibliografia completa è pubblica.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {authors.map((a) => (
          <AuthorCard name={a.name} contribution={a.contribution} year={a.year} nobel={a.nobel} />
        ))}
      </div>

      <div class="mt-12 p-6 rounded-2xl border border-white/[0.06] bg-white/[0.02] max-w-2xl">
        <h3 class="font-serif text-lg text-paper-50 mb-2">Cosa non rivendichiamo</h3>
        <p class="text-sm text-paper-300 leading-relaxed mb-3">
          Citiamo cinquant'anni di ricerca sulla memoria. Non abbiamo ancora condotto studi randomizzati su Fluera in sé — non ancora. Quando diciamo "evidence-based" intendiamo che i principi sottostanti lo sono; la nostra specifica implementazione è una scommessa ingegneristica informata dall'evidenza.
        </p>
        <p class="text-sm text-paper-300 leading-relaxed">
          Non promettiamo nemmeno l'expertise. Meta-analisi (Macnamara, Hambrick &amp; Moreau, 2014) hanno trovato che la pratica deliberata spiega circa il 4% della varianza nelle performance educative — il resto è prior knowledge, motivazione, capacità di working memory e opportunità. Fluera ottimizza il loop di pratica. Le ore, il focus, e la curiosità restano tuoi.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════ 3 · PROBLEM ═══════════ -->
  <section id="problem" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow">
      <p class="eyebrow mb-6 text-accent-glow">Il collo di bottiglia</p>
      <h2 class="font-serif text-display-xl text-paper-50 mb-8">
        Puoi chiedere qualsiasi cosa.<br />La risposta non te la ricordi lo stesso.
      </h2>
      <div class="prose-ink text-lg">
        <p>
          Nel 2026 la conoscenza si recupera in tre secondi e si dimentica in tre settimane. Abbiamo dieci app per prendere appunti e nessuna per <em>trattenere</em> ciò che impariamo.
        </p>
        <p>
          Sottolineare sembra studiare. Rileggere sembra studiare. Chiedere a un LLM un riassunto sembra studiare. Nessuna delle tre lo è — la scienza cognitiva lo dice da cinquant'anni.
        </p>
        <p>
          Il collo di bottiglia dell'apprendimento non è più l'accesso — è <em>la codifica, il consolidamento e il transfer</em>: tre problemi insieme.
        </p>
        <p class="font-serif text-paper-50 text-xl">
          Fluera è costruito per queste tre.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════ 4 · 12-STEP ═══════════ -->
  <section id="learning-cycle" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Il metodo</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          Un canvas.<br />Dodici mosse cognitive.<br />Il ciclo con cui impara il tuo cervello.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Ogni feature di Fluera vive a un passo del ciclo, e ogni passo poggia su ricerca pubblicata. Saltane uno e la catena si spezza. Seguili tutti e il quaderno diventa permanente.
        </p>
      </div>

      <ol class="max-w-3xl list-none p-0">
        {steps.map((s) => (
          <LearningStep n={s.n} title={s.title} verb={s.verb} description={s.description} />
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════ 5 · CONFRONTO COMPETITOR ═══════════ -->
  <section id="comparison" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">{comparison.kicker}</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          {comparison.title}
        </h2>
        <p class="prose-ink text-lg max-w-prose">{comparison.sub}</p>
      </div>

      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-x-auto max-w-5xl">
        <table class="w-full text-sm min-w-[640px]">
          <thead>
            <tr class="border-b border-white/[0.06]">
              <th class="text-start font-mono uppercase tracking-widest text-xs text-ink-500 px-4 py-4 w-2/5">Capacità</th>
              <th class="text-start font-serif text-base text-accent-glow px-4 py-4">{comparison.columns.fluera}</th>
              <th class="text-start font-serif text-base text-paper-200 px-4 py-4">{comparison.columns.goodNotes}</th>
              <th class="text-start font-serif text-base text-paper-200 px-4 py-4">{comparison.columns.notion}</th>
              <th class="text-start font-serif text-base text-paper-200 px-4 py-4">{comparison.columns.anki}</th>
            </tr>
          </thead>
          <tbody>
            {comparison.rows.map((r) => (
              <tr class="border-b border-white/[0.04] last:border-0">
                <td class="px-4 py-4 text-paper-200 font-medium align-top">{r.feature}</td>
                <td class="px-4 py-4 text-accent-glow align-top">{r.fluera}</td>
                <td class="px-4 py-4 text-ink-500 align-top">{r.goodNotes}</td>
                <td class="px-4 py-4 text-ink-500 align-top">{r.notion}</td>
                <td class="px-4 py-4 text-ink-500 align-top">{r.anki}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-xs text-ink-500 max-w-3xl italic">{comparison.footnote}</p>
    </div>
  </section>

  <!-- ═══════════ 6 · PILLAR FEATURES ═══════════ -->
  <section id="pillar-features" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-20">
        <p class="eyebrow mb-6 text-accent-glow">Quattro differenziatori cognitivi</p>
        <h2 class="font-serif text-display-xl text-paper-50">
          Quattro modi per ricordare davvero.
        </h2>
      </div>

      <div class="space-y-28">
        <PillarFeature
          label="Ghost Map · Passo 4"
          title="Vedi la distanza tra ciò che hai scritto e la soluzione corretta."
          description="Dopo un tentativo di recupero, Fluera sovrappone il tuo lavoro a una soluzione ideale. Le discrepanze pulsano. Non accusano — risvegliano la memoria. Più avevi torto, più la correzione si fissa."
          citation="Effetto ipercorrezione — Butterfield e Metcalfe, 2001."
          href="/beta"
          status="beta"
        />
        <PillarFeature
          label="Socratica · Passo 3"
          title="La nostra IA non risponde. Chiede."
          description="Dichiara la tua confidenza da 1 a 5 prima di ogni rivelazione. La metacognizione è metà della padronanza, e la calibrazione della confidenza è come si costruisce — una previsione alla volta."
          citation="Monitoraggio metacognitivo — Flavell, 1979."
          href="/beta"
          status="beta"
          reverse
        />
        <PillarFeature
          label="Fog of War · Passo 10"
          title="Modalità esame che nasconde ciò che quasi ricordi."
          description="Maschera qualsiasi regione del canvas. Recuperala dalla memoria. Lo sforzo del recupero — non il rivedere — è dove la memoria si indurisce."
          citation="Difficoltà desiderabili — Bjork, 1994."
          href="/beta"
          status="beta"
        />
        <PillarFeature
          label="Exam Session · Passo 11"
          title="Esami simulati dal tuo canvas — corretti da Ghost Map."
          description="Confidence picker da 1 a 5 prima di ogni domanda. Closed-book. Dopo l'invio, Fluera sovrappone la tua risposta a quella ideale e applica l'ipercorrezione dove eri più sicuro e hai sbagliato. Più grande la sorpresa, più la correzione si fissa."
          citation="Ipercorrezione — Butterfield e Metcalfe, 2001 · Productive failure — Kapur, 2008."
          href="/it/features/exam-session"
          status="beta"
          reverse
        />
      </div>

      <div class="mt-24 max-w-3xl">
        <a href="/beta" class="btn-primary">Provalo nella beta →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ 7 · WHY HANDWRITING WINS ═══════════ -->
  <section id="handwriting" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="grid md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-5">
          <p class="eyebrow mb-6 text-accent-glow">Inchiostro, non tastiera</p>
          <h2 class="font-serif text-display-lg text-paper-50 mb-6">
            Digitare è più veloce.<br />Scrivere a mano è meglio.<br />Il cervello non è ottimizzato per la velocità.
          </h2>
          <p class="text-sm text-ink-500 italic">Mueller e Oppenheimer, Princeton 2014 · van der Meer, NTNU 2020</p>
        </div>

        <div class="md:col-span-7 prose-ink text-lg">
          <p>
            Quando Mueller e Oppenheimer pubblicarono il famoso studio di Princeton nel 2014, gli studenti che prendevano appunti a mano superavano quelli al laptop sulle domande concettuali — <em>nonostante</em> i secondi avessero scritto molto più testo. La mano era più lenta. La mente era più profonda.
          </p>
          <p>
            Dieci anni dopo, l'EEG di Audrey van der Meer alla NTNU (2020) ha dato il <em>perché</em>: la scrittura a mano attiva reti cerebrali più ampie della digitazione, soprattutto nelle regioni legate alla formazione della memoria e all'integrazione sensorimotoria. La penna è uno strumento cognitivo.
          </p>
          <p>
            Fluera è costruito attorno a questo. Tredici brush engine. Pressione, tilt, velocità. Latenza del tratto sotto i 15 millisecondi su ogni dispositivo supportato. Il canvas infinito non è estetica — è il substrato che la tua memoria ti chiedeva.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ 8 · USE CASE: STUDENTI DI MEDICINA ═══════════ -->
  <section id="medical-students" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">{medicalUseCase.kicker}</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          {medicalUseCase.title}
        </h2>
        <p class="prose-ink text-lg max-w-prose">{medicalUseCase.intro}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-5xl">
        {medicalUseCase.steps.map((s) => (
          <div class="card p-6 md:p-7">
            <p class="eyebrow text-accent-glow mb-3">{s.phase}</p>
            <h3 class="font-serif text-xl text-paper-50 mb-3">{s.title}</h3>
            <p class="text-sm text-paper-300 leading-relaxed">{s.description}</p>
          </div>
        ))}
      </div>

      <p class="mt-10 prose-ink text-base max-w-3xl italic">{medicalUseCase.closing}</p>
    </div>
  </section>

  <!-- ═══════════ 9 · MULTIPLATFORM ═══════════ -->
  <section id="platforms" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Sei piattaforme, un inchiostro</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          Sei piattaforme. Un inchiostro. Una mente.
        </h2>
        <p class="prose-ink text-lg max-w-prose">
          Renderer nativi su Vulkan, Metal, OpenGL, Direct3D 11 e WebGPU. Il tuo quaderno sincronizza end-to-end cifrato, oppure resta offline. Decidi tu.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-7 gap-3">
        {platforms.map((p) => (
          <div class="card p-5 flex flex-col items-start gap-2">
            <span class="eyebrow text-accent-glow">{p.status}</span>
            <h3 class="font-serif text-lg text-paper-50">{p.name}</h3>
            <p class="text-xs text-ink-500 font-mono">{p.api}</p>
          </div>
        ))}
      </div>

      <p class="mt-6 text-xs text-ink-500 max-w-2xl">
        Le etichette di stato sono oneste sulla maturità di rilascio. Le piattaforme "Alpha" o "Demo" funzionano ma vanno rifinite — richiedi accesso anticipato se vuoi aiutarci a modellarle.
      </p>
    </div>
  </section>

  <!-- ═══════════ 10 · SECURITY & PRIVACY ═══════════ -->
  <section id="security" class="section border-t border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">La tua mente, i tuoi dati</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          End-to-end cifrato.<br />La chiave la tieni tu.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl">
        <div class="card p-6">
          <div class="eyebrow text-accent-glow mb-3">01</div>
          <h3 class="font-serif text-lg text-paper-50 mb-2">AES-256 a riposo</h3>
          <p class="text-sm text-paper-300">Cifratura SQLCipher su ogni dispositivo. Il database locale è illeggibile senza la tua chiave.</p>
        </div>
        <div class="card p-6">
          <div class="eyebrow text-accent-glow mb-3">02</div>
          <h3 class="font-serif text-lg text-paper-50 mb-2">GDPR per default</h3>
          <p class="text-sm text-paper-300">Hosting EU, DPA disponibile, esportazione e cancellazione completa su richiesta.</p>
        </div>
        <div class="card p-6">
          <div class="eyebrow text-accent-glow mb-3">03</div>
          <h3 class="font-serif text-lg text-paper-50 mb-2">Zero ad-tech</h3>
          <p class="text-sm text-paper-300">Niente pixel di tracciamento. Niente pubblicità comportamentale. Non addestriamo i nostri modelli sui tuoi contenuti.</p>
        </div>
        <div class="card p-6">
          <div class="eyebrow text-accent-glow mb-3">04</div>
          <h3 class="font-serif text-lg text-paper-50 mb-2">Audit log</h3>
          <p class="text-sm text-paper-300">Per gli account Education, ogni accesso è registrato in una traccia immutabile.</p>
        </div>
      </div>

      <div class="mt-10">
        <a href="/security" class="btn-secondary">Leggi l'architettura di sicurezza →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ 11 · PRICING SNAPSHOT ═══════════ -->
  <section id="pricing-snapshot" class="section border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Prezzi</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">
          Free per imparare. Plus e Pro per andare a fondo.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="card p-6">
          <h3 class="eyebrow text-paper-50 mb-3">Free</h3>
          <p class="font-serif text-2xl text-paper-50 mb-2">€0</p>
          <p class="text-sm text-paper-300">Il canvas completo. Tre quaderni. Gratis per sempre.</p>
        </div>
        <div class="card p-6 border-accent-ink/30 bg-accent-ink/[0.05]">
          <h3 class="eyebrow text-paper-50 mb-3">Plus</h3>
          <p class="font-serif text-2xl text-paper-50 mb-2">€5,99<span class="text-sm font-sans text-paper-300">/mese</span></p>
          <p class="text-sm text-paper-300">Canvas illimitato, sync 2 device, AI di base. €49/anno.</p>
        </div>
        <div class="card p-6">
          <h3 class="eyebrow text-paper-50 mb-3">Pro</h3>
          <p class="font-serif text-2xl text-paper-50 mb-2">€11,99<span class="text-sm font-sans text-paper-300">/mese</span></p>
          <p class="text-sm text-paper-300">Exam Session, Atlas, suite AI completa, sync illimitato. €99/anno.</p>
        </div>
      </div>

      <p class="mt-6 text-sm text-paper-300 font-medium">
        Disdici quando vuoi. Senza domande. Studenti verificati ottengono Plus o Pro al 50% tramite il programma pilota — chi sottoscrive ora blocca la tariffa per la durata dell'abbonamento.
      </p>

      <div class="mt-8">
        <a href="/pricing" class="btn-secondary">Vedi tutti i prezzi →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ 12 · BETA CTA ═══════════ -->
  <section id="beta-cta" class="section border-t border-white/[0.04] relative overflow-hidden">
    <div class="glow-orb h-[400px] w-[400px] top-0 inset-x-0 mx-auto bg-accent-ink/20 animate-orb-pulse"></div>

    <div class="container-narrow relative text-center">
      <p class="eyebrow mb-6 text-accent-glow">Unisciti a noi</p>
      <h2 class="font-serif text-display-xl text-paper-50 mb-8">
