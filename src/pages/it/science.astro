---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LearningStep from "@/components/LearningStep.astro";
import AuthorCard from "@/components/AuthorCard.astro";
import { getCollection } from "astro:content";

const principles = (await getCollection("principles", ({ data }) => data.lang === "it")).sort(
  (a, b) => a.data.order - b.data.order,
);
const authors = (await getCollection("authors", ({ data }) => data.lang === "it")).sort(
  (a, b) => a.data.order - b.data.order,
);

const steps = [
  { n: 1,  title: "Cattura",             verb: "Giorno lezione",         description: "Scrivi i concetti a mano durante la lezione. Posizionali nello spazio. La lentezza della penna forza compressione — e la compressione è dove nasce la codifica." },
  { n: 2,  title: "Ricostruzione",       verb: "Stessa sera",            description: "Chiudi il libro. Ricostruisci ciò che ricordi su un canvas vuoto. I nodi rossi dove vacilli sono la mappa di cosa studiare (Kapur, productive failure, 2008)." },
  { n: 3,  title: "Socratica",           verb: "Entro 48h",              description: "L'IA chiede, tu rispondi. Dichiari la confidenza da 1 a 5 prima di ogni rivelazione. Metacognizione resa esplicita." },
  { n: 4,  title: "Centauro",            verb: "Subito dopo",            description: "Ghost Map sovrappone il tuo ragionamento alla mappa ideale. L'ipercorrezione fissa le correzioni nella memoria (Butterfield e Metcalfe, 2001)." },
  { n: 5,  title: "Sonno",               verb: "Quella notte",           description: "Non fare nulla. Il sonno a onde lente rigioca il giorno. L'ippocampo passa le tracce alla neocorteccia." },
  { n: 6,  title: "Primo ritorno",       verb: "Giorno 1",               description: "Apri il canvas il giorno dopo. Quello che quasi sapevi sbiadisce. Lo recuperi dalla memoria prima di rivelarlo." },
  { n: 7,  title: "Apprendimento solidale", verb: "Giorni 2–3",          description: "Spiega il tuo canvas a un compagno — o a un'IA silenziosa che chiede a rimbalzo. Insegnare a qualcun altro è come si finisce di insegnarsi da soli." },
  { n: 8,  title: "Ritorni spaziati",    verb: "Giorno 3 · 7 · 14…",     description: "Successive relearning su intervalli crescenti. Per effect size, la strategia di studio con l'evidenza più forte (Rawson e Dunlosky, 2011)." },
  { n: 9,  title: "Ponti cross-dominio", verb: "Settimane dopo",         description: "Traccia frecce tra le materie. La chimica incontra le equazioni differenziali. Il transfer è il vero test dell'apprendimento." },
  { n: 10, title: "Preparazione esame",  verb: "7–14 giorni prima",      description: "Fog of War. Naviga nella nebbia del tuo canvas. Verde, rosso, punti ciechi — la mappa della padronanza si disegna da sola." },
  { n: 11, title: "L'esame",             verb: "Il giorno",              description: "Chiudi il dispositivo. Cammina nel palazzo della memoria che hai costruito con le mani per settimane. Il canvas vive in te ora." },
  { n: 12, title: "Crescita permanente", verb: "Per sempre",             description: "Il canvas persiste come autobiografia cognitiva. Torni dopo due anni e vedi la forma tangibile di quanto sei cresciuto." },
];
---

<BaseLayout
  title="La scienza di Fluera"
  description="Fluera poggia su cinque decenni di ricerca sulla memoria — Bjork, Mueller, van der Meer, Roediger, e la neuroscienza premio Nobel delle place cell. Esplora il ciclo in 12 passi e i principi dietro ogni funzione."
  locale="it"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04] relative overflow-hidden noise">
    <div class="glow-orb h-[500px] w-[500px] -top-32 -start-40 bg-accent-ink/25 animate-orb-pulse"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6 text-accent-glow">La scienza</p>
        <h1 class="font-serif text-display-2xl text-paper-50 mb-6">
          Cinque decenni di ricerca sulla memoria<br />dietro una sola app.
        </h1>
        <p class="prose-ink text-xl max-w-2xl mb-10">
          Ogni funzione di Fluera risale a ricerca pubblicata. Qui sotto: il ciclo di apprendimento in 12 passi, i 23 principi alla base, le dodici menti su cui costruiamo, e i limiti di ciò che non pretendiamo ancora.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#learning-cycle" class="btn-secondary">Vai al ciclo</a>
          <a href="#principles" class="btn-secondary">Indice dei principi</a>
          <a href="#authors" class="btn-secondary">Autori</a>
          <a href="/it/research" class="btn-secondary">Bibliografia →</a>
        </div>
      </div>
    </div>
  </section>

  <section id="learning-cycle" class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Il ciclo</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">Un canvas. Dodici mosse cognitive.</h2>
        <p class="prose-ink text-lg max-w-prose">
          Il ciclo è sequenziale e iterativo. I passi 1–4 costruiscono la codifica. Il passo 5 (sonno) è biologia non negoziabile. I passi 6–9 consolidano nell'arco di giorni e settimane. I passi 10–12 rendono la conoscenza permanente e trasferibile.
        </p>
      </div>

      <ol class="max-w-3xl list-none p-0">
        {steps.map((s) => (
          <LearningStep n={s.n} title={s.title} verb={s.verb} description={s.description} />
        ))}
      </ol>
    </div>
  </section>

  <section id="principles" class="py-20 md:py-28 border-b border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow mb-6 text-accent-glow">Indice dei principi</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">I 23 principi dietro Fluera.</h2>
        <p class="prose-ink text-lg max-w-prose">
          Ogni principio linka a una pagina dedicata con autori primari, funzioni applicate e i paper che citiamo.
        </p>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {principles.map((p) => (
          <li>
            <a
              href={`/it/science/principles/${p.id.replace(/\.it$/, "")}`}
              class="block card p-5 h-full transition-all hover:border-accent-glow/40 hover:bg-white/[0.04]"
            >
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-serif text-base font-medium text-paper-50 leading-tight">{p.data.title}</h3>
                <span class="shrink-0 text-[10px] font-mono uppercase tracking-widest text-ink-500">{p.data.keyYear}</span>
              </div>
              <p class="text-sm text-paper-300 leading-relaxed line-clamp-3">{p.data.shortDescription}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section id="authors" class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">Le menti dietro il metodo</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">Dodici ricercatori il cui lavoro vive dentro Fluera.</h2>
        <p class="prose-ink text-lg max-w-prose">
          Non è una pagina-tributo. Ogni nome rimanda a una pagina che nomina il principio, le funzioni Fluera che lo implementano e i paper che citiamo.
        </p>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 list-none p-0">
        {authors.map((a) => (
          <li>
            <a href={`/it/science/authors/${a.id.replace(/\.it$/, "")}`} class="block">
              <AuthorCard name={a.data.name} contribution={a.data.shortBio.slice(0, 160) + (a.data.shortBio.length > 160 ? "…" : "")} year={a.data.years} nobel={a.data.nobelLaureate} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04] bg-ink-900/40">
    <div class="container-prose">
      <p class="eyebrow mb-6 text-accent-glow">Perché oggi</p>
      <h2 class="font-serif text-display-lg text-paper-50 mb-8">Il collo di bottiglia si è spostato.</h2>
      <div class="prose-ink text-lg">
        <p>
          Per gran parte della storia, il collo di bottiglia dell'apprendimento era l'accesso. I libri costavano, gli insegnanti erano pochi, le biblioteche lontane. La domanda era: <em>riesco ad arrivare all'informazione?</em>
        </p>
        <p>
          Per l'ultima generazione, il collo di bottiglia era la navigazione. L'informazione era abbondante; trovare il pezzo giusto era il lavoro. Google, Wikipedia, cataloghi di corsi — un'infrastruttura intera per una domanda: <em>dove si trova?</em>
        </p>
        <p>
          Nel 2026 nessuna delle due vincola più. Qualsiasi fatto è a tre secondi. Qualsiasi spiegazione si può generare nello stile che preferisci. Il collo di bottiglia ha cambiato forma, e per la nuova forma l'infrastruttura ancora non l'abbiamo costruita: <em>come trasformo ciò che ho appena letto in qualcosa che tengo davvero?</em>
        </p>
        <p>
          La scienza cognitiva di questa domanda è chiara da cinquant'anni. Ripetizione spaziata, retrieval practice, generazione, desirable difficulties, cognizione incarnata, calibrazione metacognitiva. I risultati sono robusti. Le meta-analisi sono coerenti. Il problema non è mai stato sapere cosa funziona — è stato costruire strumenti che rendano la cosa giusta la via più facile.
        </p>
        <p>
          La tentazione dell'era LLM è l'opposto. Fa sentire la cosa sbagliata — il consumo passivo di spiegazioni fluenti — come se fosse quella giusta. Tre secondi di riconoscimento, scambiati per codifica. Non serve un'altra app che acceleri quello sbaglio.
        </p>
        <p>
          Fluera è costruito controcorrente. Lento dove la velocità è un'illusione. Silenzioso dove il rumore è il modello di business. Difficile dove la difficoltà è il meccanismo. Non perché ci piaccia la fatica, ma perché l'evidenza è inequivocabile — la fatica <em>è</em> l'apprendimento.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-prose">
      <p class="eyebrow mb-6 text-accent-glow">Trasparenza</p>
      <h2 class="font-serif text-display-lg text-paper-50 mb-8">Cosa non pretendiamo.</h2>
      <div class="prose-ink text-lg">
        <p>
          Citiamo ricerca per ogni principio perché la ricerca c'è. Questo non significa che Fluera stessa sia stata testata contro controlli. Non lo è — non ancora. Quando diciamo "basato sull'evidenza", intendiamo che il meccanismo sottostante lo è. L'implementazione specifica è una scommessa ingegneristica informata dalla letteratura.
        </p>
        <p>
          Non siamo uno strumento clinico. Non sostituiamo un tutor competente. Non dichiareremo che usare Fluera alza il risultato di nessuno studente di nessuna percentuale specifica. Un'affermazione del genere sarebbe disonesta o infalsificabile; entrambe peggio del silenzio.
        </p>
        <p>
          Alcuni dei principi elencati sono contestati in domini specifici. Gli interventi sul growth mindset hanno replicazione mista in trial controllati. Il flow è più facile da riconoscere che da ingegnerizzare con affidabilità. La cognizione spaziale negli ambienti digitali non sempre combacia con quella negli ambienti fisici. Segnaliamo questi limiti perché appiattirli è il modo più veloce di perdere la fiducia esattamente dei learner che ci interessano.
        </p>
        <p>
          Le meta-analisi che citiamo sono il consenso più vicino che la scienza cognitiva produce. Le funzioni Fluera costruite su di esse sono, in questo momento, ipotesi che testiamo con la beta. Se qualcosa non funziona per te, vogliamo saperlo — quel segnale vale più di qualsiasi claim da landing page.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-ink-900/40">
    <div class="container-narrow text-center">
      <h2 class="font-serif text-display-lg text-paper-50 mb-4">Prova il ciclo.</h2>
      <p class="prose-ink mb-8 max-w-2xl mx-auto">
        Leggere di retrieval practice non è retrieval practice. Entra nella beta privata e metti il ciclo alla prova su un canvas tuo.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/beta" class="btn-primary">Entra nella beta →</a>
        <a href="/it/research" class="btn-secondary">Leggi la bibliografia</a>
      </div>
    </div>
  </section>

</BaseLayout>
