---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";

const platforms = [
  { name: "iOS / iPadOS", status: "Beta",  note: "Invito TestFlight dopo l'approvazione nella beta." },
  { name: "macOS",        status: "Beta",  note: "File .dmg via link privato dopo l'approvazione." },
  { name: "Android",      status: "Alpha", note: "APK via Google Play internal track." },
  { name: "Windows",      status: "Alpha", note: "Installer .exe firmato via Microsoft Store." },
  { name: "Linux",        status: "Alpha", note: "AppImage + flatpak." },
  { name: "Web",          status: "Demo",  note: "Provala ora su /demo — browser con WebGPU richiesto." },
];
---

<BaseLayout
  title="Scarica"
  description="Fluera gira nativo su iOS, Android, macOS, Windows, Linux e sul web. Entra nella beta privata per l'accesso anticipato."
  locale="it"
>
  <PageHero
    kicker="Scarica"
    title="Sei piattaforme.<br />Entra nella beta per l'accesso."
    description="Fluera è in beta privata. Una volta dentro, i link di installazione arrivano via email — nativo su ogni piattaforma, niente wrapper nel browser."
  >
    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {platforms.map((p) => (
        <article class="card p-6">
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-serif text-lg text-paper-50">{p.name}</h2>
            <span class="pill text-[10px]">{p.status}</span>
          </div>
          <p class="text-sm text-paper-300 leading-relaxed">{p.note}</p>
        </article>
      ))}
    </div>

    <div class="flex flex-wrap gap-4">
      <a href="/beta" class="btn-primary">Richiedi l'accesso beta →</a>
      <a href="/demo" class="btn-secondary">Prova la demo web</a>
    </div>
  </PageHero>

  <section class="py-16 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow text-center">
      <p class="text-sm text-ink-500 max-w-xl mx-auto leading-relaxed">
        Le pubblicazioni pubbliche su App Store e Google Play arrivano alla fine della beta privata. Nel frattempo, le etichette di stato qui sopra dicono la verità sulla maturità di ogni piattaforma — preferiamo rilasciare bene su una sola che male su sei.
      </p>
    </div>
  </section>
</BaseLayout>
