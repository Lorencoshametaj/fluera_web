---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? "";
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "";
const configured =
  supabaseUrl &&
  supabaseKey &&
  !supabaseUrl.includes("YOUR-PROJECT-REF") &&
  !supabaseKey.includes("YOUR_ANON");

const description =
  "Dołącz do prywatnej bety Fluery: nieskończona kanwa + AI + nauka poznawcza uczenia się. Dostęp na podstawie kohort.";
---

<BaseLayout
  title="Beta Fluery — nauka oparta na nauce poznawczej"
  description={description}
  locale="pl"
>

  <section class="relative py-20 md:py-28 overflow-hidden noise">
    <div class="glow-orb h-[400px] w-[400px] -top-24 -start-36 bg-accent-ink/30 animate-orb-pulse"></div>
    <div class="glow-orb h-[350px] w-[350px] top-24 -end-24 bg-accent-glow/25 animate-orb-pulse" style="animation-delay: -2s"></div>

    <div class="container-narrow relative text-center">
      <div class="pill mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-accent-glow animate-pulse"></span>
        Prywatna beta · dostęp na podstawie kohort
      </div>
      <h1 class="font-serif text-display-xl text-paper-50 mb-6">
        Nauka<br />
        <span class="text-gradient">prowadzona przez naukę poznawczą</span>
      </h1>
      <p class="prose-ink text-lg mb-10 max-w-2xl mx-auto">
        Nieskończona kanwa, zintegrowane AI, 12-stopniowy cykl nauki oparty na <em>powtórkach rozłożonych</em>, <em>praktyce wydobywania</em> i <em>produktywnej porażce</em>.
        Nie aplikacja do rysowania ani alternatywa dla Anki: punkt, w którym oba się spotykają.
      </p>

      <div class="grid sm:grid-cols-3 gap-4 text-start max-w-2xl mx-auto">
        <div class="card p-4">
          <p class="font-serif text-sm font-medium text-paper-50 mb-1.5">Ghost Map</p>
          <p class="text-xs text-paper-300 leading-relaxed">
            AI buduje z Tobą mapę pojęć i pokazuje, czego brakuje.
          </p>
        </div>
        <div class="card p-4">
          <p class="font-serif text-sm font-medium text-paper-50 mb-1.5">Spersonalizowany FSRS</p>
          <p class="text-xs text-paper-300 leading-relaxed">
            Nowoczesne powtórki rozłożone, kalibrowane na Twoich rzeczywistych powtórkach.
          </p>
        </div>
        <div class="card p-4">
          <p class="font-serif text-sm font-medium text-paper-50 mb-1.5">Socratic Mode</p>
          <p class="text-xs text-paper-300 leading-relaxed">
            AI zadaje Ci pytania zamiast odpowiadać. Faktycznie myślisz.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-narrow max-w-xl">

      {!configured && (
        <div class="mb-6 rounded-xl border border-dashed border-signal-bad/40 bg-signal-bad/[0.08] px-4 py-3 text-xs font-mono text-red-300">
          ⚠️ Skonfiguruj <code>PUBLIC_SUPABASE_URL</code> i <code>PUBLIC_SUPABASE_ANON_KEY</code> w <code>.env</code> przed wdrożeniem.
        </div>
      )}

      <div class="card p-6 md:p-8">
        <h2 class="font-serif text-xl text-paper-50 mb-1">Poproś o dostęp</h2>
        <p class="text-sm text-ink-500 mb-6">
          Odpowiedzi pomagają nam zrozumieć, <em>kogo</em> zaprosić w pierwszej kolejności. Im szczerzej, tym lepiej.
        </p>

        <form id="waitlist-form" novalidate>
          <div class="honeypot" aria-hidden="true">
            <label>Nie wypełniaj: <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </div>

          <div class="space-y-5">
            <div>
              <label class="field-label" for="f-name">Imię (opcjonalnie)</label>
              <input id="f-name" name="name" type="text" class="field-input" placeholder="Jak mamy się do Ciebie zwracać?" maxlength="80" autocomplete="given-name" />
            </div>

            <div>
              <label class="field-label" for="f-email">E-mail <span class="text-signal-bad">*</span></label>
              <input id="f-email" name="email" type="email" class="field-input" placeholder="ty@uniwersytet.edu" required maxlength="254" autocomplete="email" />
              <p class="field-hint">Użyj tego, który kontrolujesz — tam napiszemy.</p>
            </div>

            <div>
              <span class="field-label">Studiujesz czy pracujesz? <span class="text-signal-bad">*</span></span>
              <div class="flex flex-wrap gap-2 mt-1">
                <label class="role-pill"><input type="radio" name="role" value="student" required> Student</label>
                <label class="role-pill"><input type="radio" name="role" value="professional"> Profesjonalista / pracownik wiedzy</label>
                <label class="role-pill"><input type="radio" name="role" value="educator"> Nauczyciel / wykładowca</label>
                <label class="role-pill"><input type="radio" name="role" value="other"> Inne</label>
              </div>
            </div>

            <div data-show-when-role="student educator">
              <label class="field-label" for="f-faculty">Wydział lub kierunek studiów</label>
              <input id="f-faculty" name="faculty" type="text" class="field-input" placeholder="np. medycyna, informatyka…" minlength="2" maxlength="120" />
              <p class="field-hint">Wymagane, jeśli jesteś studentem lub nauczycielem.</p>
            </div>

            <div data-show-when-role="professional">
              <label class="field-label" for="f-domain">Dziedzina pracy</label>
              <input id="f-domain" name="work_domain" type="text" class="field-input" placeholder="np. projektant produktu, badacz biotech, prawnik…" minlength="2" maxlength="120" />
              <p class="field-hint">O czym myślisz cały dzień.</p>
            </div>

            <div data-show-when-role="student">
              <label class="field-label" for="f-year">Rok studiów</label>
              <select id="f-year" name="study_year" class="field-select">
                <option value="" disabled selected>Wybierz…</option>
                <option value="0">Liceum / przed studiami</option>
                <option value="1">Pierwszy rok</option>
                <option value="2">Drugi rok</option>
                <option value="3">Trzeci rok</option>
                <option value="4">Czwarty rok</option>
                <option value="5">Piąty rok</option>
                <option value="6">Szósty rok</option>
                <option value="7">Poza programem</option>
                <option value="8">Specjalizacja / doktorat</option>
              </select>
            </div>

            <div>
              <label class="field-label" for="f-device">Główne urządzenie <span class="text-signal-bad">*</span></label>
              <select id="f-device" name="device" class="field-select" required>
                <option value="" disabled selected>Wybierz…</option>
                <option value="ipad">iPad + Apple Pencil</option>
                <option value="iphone">iPhone</option>
                <option value="android_tablet">Tablet Android + rysik</option>
                <option value="android_phone">Smartfon Android</option>
                <option value="macos">Mac (MacBook / iMac)</option>
                <option value="windows">PC z Windows</option>
                <option value="linux">Pulpit Linux</option>
                <option value="web">Przeglądarka internetowa</option>
                <option value="altro">Inne</option>
              </select>
              <p class="field-hint">Gdzie myślisz każdego dnia.</p>
            </div>

            <div>
              <span class="field-label">Czego używasz dziś? <span class="text-ink-500 font-normal">(zaznacz tyle, ile chcesz)</span></span>
              <div class="flex flex-wrap gap-2 mt-1">
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="anki"> Anki</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="notability"> Notability</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="goodnotes"> GoodNotes</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="onenote"> OneNote</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="obsidian"> Obsidian</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="notion"> Notion</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="paper"> Papier i długopis</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="pdf_reader"> Czytnik PDF</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="nessuno"> Nic</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="altro"> Inne</label>
              </div>
            </div>

            <div>
              <label class="field-label" for="f-pain">
                Jaki jest najbardziej frustrujący moment w sposobie, w jaki dziś się uczysz lub myślisz? <span class="text-signal-bad">*</span>
              </label>
              <textarea id="f-pain" name="main_pain" rows="4" class="field-textarea"
                placeholder="Opowiedz dobrze. Wystarczą 2-3 zdania — pomyśl, co chcesz rozwiązać."
                required minlength="10" maxlength="2000"></textarea>
              <p class="field-hint">To pole waży więcej niż inne podczas selekcji.</p>
            </div>

            <div>
              <label class="field-label" for="f-referral">Skąd nas znasz?</label>
              <select id="f-referral" name="referral_source" class="field-select">
                <option value="">Wolę nie mówić</option>
                <option value="reddit">Reddit</option>
                <option value="twitter">Twitter / X</option>
                <option value="tiktok">TikTok</option>
                <option value="instagram">Instagram</option>
                <option value="youtube">YouTube</option>
                <option value="telegram">Telegram / WhatsApp</option>
                <option value="amici">Z polecenia / znajomi</option>
                <option value="google">Wyszukiwarka Google</option>
                <option value="hn">Hacker News</option>
                <option value="altro">Inne</option>
              </select>
            </div>

            <div class="pt-2">
              <label class="flex items-start gap-3 cursor-pointer">
                <input id="f-consent" type="checkbox" name="consent_privacy" required
                  class="mt-0.5 w-4 h-4 rounded border-white/20 bg-ink-900 text-accent-ink focus:ring-accent-ink" />
                <span class="text-sm text-paper-300 leading-relaxed">
                  Przeczytałem/-am i akceptuję <a href="/legal/privacy" class="text-accent-glow underline">Politykę prywatności</a>
                  oraz <a href="/legal/terms" class="text-accent-glow underline">Regulamin</a>.
                  Wyrażam zgodę na przetwarzanie danych w celu kontaktu w sprawie prywatnej bety Fluery.
                </span>
              </label>
            </div>

            <div class="pt-2">
              <button id="submit-btn" type="submit" class="btn-primary w-full py-3.5">
                <span id="submit-label">Dołącz do listy oczekujących</span>
                <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"></circle>
                  <path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
                </svg>
              </button>

              <div id="status-success" class="hidden mt-5 p-4 rounded-xl border border-signal-ok/30 bg-signal-ok/10">
                <p class="text-sm text-emerald-300 font-medium">✓ Jesteś na liście.</p>
                <p class="text-xs text-emerald-200/70 mt-1">
                  Napiszemy z <code>{SITE.company.privacyEmail}</code>, gdy tylko otworzymy następne miejsca.
                </p>
              <p id="waitlist-position" class="hidden text-xs text-emerald-200/80 mt-2">
                  You're <span class="font-mono font-medium text-paper-100">#<span id="waitlist-position-num">…</span></span> in line.
                </p>
                <div class="mt-4 pt-3 border-t border-emerald-400/15 flex flex-wrap gap-2">
                  <a
                    href={`https://twitter.com/intent/tweet?text=${encodeURIComponent("Just joined the Fluera waitlist — a study app for people who take cognitive science seriously. ")}&url=${encodeURIComponent("https://fluera.dev/beta")}`}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-white/10 hover:border-accent-glow/40 text-xs text-paper-200 hover:text-paper-50 transition-colors"
                  >
                    Share Fluera ↗
                  </a>
                  <a
                    href="/blog"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-white/10 hover:border-accent-glow/40 text-xs text-paper-200 hover:text-paper-50 transition-colors"
                  >
                    Read the blog →
                  </a>
                </div>
              </div>

              <div id="status-already" class="hidden mt-5 p-4 rounded-xl border border-accent-ink/30 bg-accent-ink/10">
                <p class="text-sm text-blue-200">Ten e-mail jest już na liście. Wszystko w porządku 🙂</p>
              </div>

              <div id="status-error" class="hidden mt-5 p-4 rounded-xl border border-signal-bad/30 bg-signal-bad/10">
                <p class="text-sm text-red-300 font-medium">Coś poszło nie tak.</p>
                <p id="status-error-detail" class="text-xs text-red-200/70 mt-1"></p>
              </div>
            </div>
          </div>
        </form>
      </div>

      <p class="text-xs text-ink-500 text-center mt-6">
        Odpowiedzi są przetwarzane zgodnie z <a href="/legal/privacy" class="text-paper-300 underline">Polityką prywatności</a>.
        Nie udostępniamy ich stronom trzecim ani nie wykorzystujemy do reklam.
      </p>
    </div>
  </section>

  <style>
    .field-label { display: block; font-size: 0.875rem; font-weight: 500; color: theme("colors.paper.200"); margin-bottom: 0.5rem; }
    .field-hint  { font-size: 0.75rem; color: theme("colors.ink.500"); margin-top: 0.375rem; }
    .field-input, .field-select, .field-textarea {
      width: 100%; background: theme("colors.ink.900"); border: 1px solid rgb(255 255 255 / 0.08);
      border-radius: 0.625rem; padding: 0.75rem 1rem; color: theme("colors.paper.50"); font-size: 0.95rem;
      transition: all 0.2s;
    }
    .field-input:focus, .field-select:focus, .field-textarea:focus {
      outline: none; border-color: theme("colors.accent.ink"); box-shadow: 0 0 0 3px rgb(45 74 222 / 0.18);
    }
    .field-input:invalid:not(:placeholder-shown),
    .field-textarea:invalid:not(:placeholder-shown) {
      border-color: rgb(239 68 68 / 0.5);
    }
    .tool-pill, .role-pill {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.5rem 0.875rem; border: 1px solid rgb(255 255 255 / 0.08);
      border-radius: 999px; cursor: pointer; user-select: none;
      background: theme("colors.ink.900"); font-size: 0.875rem; color: theme("colors.paper.200");
      transition: all 0.15s;
    }
    .tool-pill:hover, .role-pill:hover { border-color: rgb(56 189 248 / 0.4); color: theme("colors.paper.50"); }
    .tool-pill input, .role-pill input { display: none; }
    .tool-pill:has(input:checked),
    .role-pill:has(input:checked) {
      background: rgb(45 74 222 / 0.15); border-color: theme("colors.accent.ink"); color: theme("colors.accent.glow");
    }
    [data-show-when-role] { display: none; }
    [data-show-when-role].is-visible { display: block; }
    .honeypot {
      position: absolute; inset-inline-start: -9999px; width: 1px; height: 1px; opacity: 0; pointer-events: none;
    }

    /* ── Light-theme overrides for scoped beta-form styles ─────────────── */
    :global(html.light) .field-label { color: #1f242c; }
    :global(html.light) .field-hint { color: #586173; }
    :global(html.light) .field-input,
    :global(html.light) .field-select,
    :global(html.light) .field-textarea {
      background: #ffffff; border-color: rgb(0 0 0 / 0.10); color: #16181d;
    }
    :global(html.light) .tool-pill,
    :global(html.light) .role-pill {
      background: #ffffff; border-color: rgb(0 0 0 / 0.10); color: #3a4150;
    }
    :global(html.light) .tool-pill:hover,
    :global(html.light) .role-pill:hover { border-color: rgb(37 99 235 / 0.45); color: #16181d; }
    :global(html.light) .tool-pill:has(input:checked),
    :global(html.light) .role-pill:has(input:checked) {
      background: rgb(37 99 235 / 0.10); border-color: theme("colors.accent.ink"); color: #2563eb;
    }
  </style>

  <script is:inline define:vars={{ supabaseUrl, supabaseKey, configured }}>
    const form       = document.getElementById("waitlist-form");
    const btn        = document.getElementById("submit-btn");
    const btnLabel   = document.getElementById("submit-label");
    const btnSpinner = document.getElementById("submit-spinner");
    const okBox      = document.getElementById("status-success");
    const dupeBox    = document.getElementById("status-already");
    const errBox     = document.getElementById("status-error");
    const errDetail  = document.getElementById("status-error-detail");
    const renderedAt = Date.now();

    const conditionalBlocks = Array.from(form.querySelectorAll("[data-show-when-role]"));
    const facultyInput = form.querySelector('input[name="faculty"]');
    const domainInput  = form.querySelector('input[name="work_domain"]');
    const yearSelect   = form.querySelector('select[name="study_year"]');

    function applyRoleVisibility() {
      const role = (form.querySelector('input[name="role"]:checked') || {}).value || "";
      conditionalBlocks.forEach((el) => {
        const allowed = (el.getAttribute("data-show-when-role") || "").split(/\s+/);
        const visible = allowed.includes(role);
        el.classList.toggle("is-visible", visible);
        el.querySelectorAll("input, select, textarea").forEach((field) => {
          field.disabled = !visible;
          if (!visible) field.required = false;
        });
      });
      if (facultyInput) facultyInput.required = (role === "student" || role === "educator");
      if (domainInput)  domainInput.required  = (role === "professional");
      if (yearSelect)   yearSelect.required   = (role === "student");
    }
    form.querySelectorAll('input[name="role"]').forEach((r) => r.addEventListener("change", applyRoleVisibility));
    applyRoleVisibility();

    function hideStatuses() {
      okBox.classList.add("hidden");
      dupeBox.classList.add("hidden");
      errBox.classList.add("hidden");
    }
    function setLoading(loading) {
      btn.disabled = loading;
      btnLabel.textContent = loading ? "Wysyłanie…" : "Dołącz do listy oczekujących";
      btnSpinner.classList.toggle("hidden", !loading);
    }
    function showError(msg) { errDetail.textContent = msg; errBox.classList.remove("hidden"); }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideStatuses();

      if (!form.checkValidity()) { form.reportValidity(); return; }
      if (!configured) {
        showError("Backend nie skonfigurowany. Ustaw PUBLIC_SUPABASE_URL + anon key w .env.");
        return;
      }
      if (Date.now() - renderedAt < 2000) {
        okBox.classList.remove("hidden"); form.reset(); return;
      }

      const formData = new FormData(form);
      const tools = Array.from(
        form.querySelectorAll('input[name="current_tools"]:checked')
      ).map(i => i.value);

      const role = formData.get("role") || "";
      const facultyVal = (formData.get("faculty") || "").trim();
      const domainVal  = (formData.get("work_domain") || "").trim();
      const yearRaw    = formData.get("study_year");
      const yearVal    = yearRaw ? parseInt(yearRaw, 10) : null;

      const payload = {
        p_email:           (formData.get("email") || "").trim(),
        p_faculty:         facultyVal || domainVal || role,
        p_study_year:      Number.isFinite(yearVal) ? yearVal : 9,
        p_device:          formData.get("device"),
        p_current_tools:   tools,
        p_main_pain:       (formData.get("main_pain") || "").trim(),
        p_consent_privacy: formData.get("consent_privacy") === "on",
        p_name:            (formData.get("name") || "").trim() || null,
        p_referral_source: formData.get("referral_source") || null,
        p_locale:          navigator.language || null,
        p_user_agent:      navigator.userAgent.slice(0, 500),
        p_honeypot:        (formData.get("website") || "").trim() || null,
      };

      setLoading(true);
      try {
        const resp = await fetch(`${supabaseUrl}/rest/v1/rpc/submit_waitlist`, {
          method: "POST",
          headers: {
            apikey: supabaseKey,
            Authorization: `Bearer ${supabaseKey}`,
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(payload),
        });
        if (!resp.ok) throw new Error((await resp.text()) || `HTTP ${resp.status}`);
        const result = await resp.json();
        if (result && result.already_signed) {
          dupeBox.classList.remove("hidden");
        } else {
          okBox.classList.remove("hidden");
          form.reset();
          applyRoleVisibility();

          // Fire-and-forget sync to Loops (welcome email + nurture sequence).
          // Failure here is non-critical — Supabase already has the data.
          const fullName = (formData.get("name") || "").trim();
          const firstName = fullName.split(/\s+/)[0] || "";
          const loopsBody = new URLSearchParams({ email: payload.p_email });
          if (firstName) loopsBody.set("firstName", firstName);
          loopsBody.set("userGroup", "beta-waitlist");
          loopsBody.set("source", payload.p_referral_source || "fluera.dev");
          fetch("https://app.loops.so/api/newsletter-form/cmpb3hw2h06r50jyq0qx9jujs", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: loopsBody.toString(),
          }).catch((loopsErr) => {
            console.warn("Loops sync failed (non-critical):", loopsErr);
          });

          // Fetch waitlist count for "you're #X in line" display.
          // Fire-and-forget: if the RPC fails (e.g. not deployed yet), we silently
          // skip the position display rather than breaking the success state.
          fetch(`${supabaseUrl}/rest/v1/rpc/get_waitlist_count`, {
            method: "POST",
            headers: {
              apikey: supabaseKey,
              Authorization: `Bearer ${supabaseKey}`,
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: "{}",
          })
            .then((r) => (r.ok ? r.json() : null))
            .then((count) => {
              if (typeof count === "number" && count > 0) {
                const numEl = document.getElementById("waitlist-position-num");
                const posEl = document.getElementById("waitlist-position");
                if (numEl && posEl) {
                  numEl.textContent = String(count);
                  posEl.classList.remove("hidden");
                }
              }
            })
            .catch((countErr) => {
              console.warn("Waitlist count fetch failed (non-critical):", countErr);
            });
        }
      } catch (err) {
        console.error("Waitlist submit failed:", err);
        showError("Spróbuj ponownie za kilka sekund. Jeśli problem nadal występuje, napisz na support@fluera.dev.");
      } finally {
        setLoading(false);
      }
    });
  </script>

</BaseLayout>
