---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LearningStep from "@/components/LearningStep.astro";
import AuthorCard from "@/components/AuthorCard.astro";
import { getCollection } from "astro:content";

const principles = (await getCollection("principles", ({ data }) => data.lang === "en")).sort(
  (a, b) => a.data.order - b.data.order,
);
const authors = (await getCollection("authors", ({ data }) => data.lang === "en")).sort(
  (a, b) => a.data.order - b.data.order,
);

const steps = [
  { n: 1,  title: "الالتقاط",                verb: "يوم المحاضرة",            description: "اكتب المفاهيم بخطّ يدك خلال المحاضرة. ضعها في موضع. بطء القلم يفرض الضغط — والضغط هو حيث يولد الترميز." },
  { n: 2,  title: "إعادة البناء",            verb: "في المساء نفسه",          description: "أغلق الكتاب. أعد بناء ما تتذكّره على لوحة فارغة. العقد الحمراء التي تتعثّر فيها هي خريطة جلسة الدراسة التالية (Kapur، الفشل المنتج، 2008)." },
  { n: 3,  title: "السقراطية",                verb: "خلال 48 ساعة",            description: "الذكاء الاصطناعي يسأل، أنت تجيب. قبل كلّ كشف، قيّم الثقة من 1 إلى 5. ما وراء المعرفة تصبح صريحة." },
  { n: 4,  title: "القنطور",                  verb: "مباشرة بعد ذلك",          description: "Ghost Map يضع تفكيرك فوق الخريطة المثالية. المبالغة في التصحيح تُثبّت التصحيحات في الذاكرة (Butterfield وMetcalfe، 2001)." },
  { n: 5,  title: "النوم",                    verb: "تلك الليلة",              description: "لا تفعل شيئًا. نوم الموجات البطيئة يُعيد تشغيل اليوم. الحُصين يسلّم الآثار إلى القشرة المخّية الحديثة." },
  { n: 6,  title: "العودة الأولى",             verb: "اليوم 1",                 description: "افتح اللوحة في اليوم التالي. ما كنت تعرفه تقريبًا يصبح ضبابيًّا. استرجِع من الذاكرة قبل الكشف." },
  { n: 7,  title: "التعلّم مع شريك",            verb: "اليوم 2-3",               description: "اشرح لوحتك لزميل — أو لذكاء اصطناعي صامت يسأل عن الإعادات. أن تُعلِّم الآخرين هو طريقة لتعليم نفسك." },
  { n: 8,  title: "المراجعة المتباعدة",         verb: "اليوم 3 · 7 · 14…",       description: "إعادة التعلّم الناجحة على فترات متزايدة. الاستراتيجية الأقوى دليلًا في علم التعلّم (Rawson وDunlosky، 2011)." },
  { n: 9,  title: "جسور بين المجالات",          verb: "بعد أسابيع",             description: "ارسم سهامًا بين المواضيع. الكيمياء تلتقي بالمعادلات التفاضلية. الانتقال هو الاختبار الحقيقي للتعلّم." },
  { n: 10, title: "التحضير للامتحان",           verb: "قبل 7-14 يومًا من الامتحان", description: "Fog of War. تنقّل في ضباب لوحتك. النقاط الخضراء والحمراء والعمياء — خريطة الإتقان ترسم نفسها." },
  { n: 11, title: "Exam Session",              verb: "قبل 7 أيّام · يوم الامتحان", description: "Fluera تُولِّد امتحانًا مغلق الكتاب من لوحتك. قيّم الثقة من 1 إلى 5، أجِب بخطّ يدك. Ghost Map يكشف الفجوة." },
  { n: 12, title: "النموّ الدائم",               verb: "إلى الأبد",              description: "تبقى اللوحة بمثابة سيرة ذاتية معرفية. عُد بعد عامين وانظر إلى مدى نموّك في صورة ملموسة." },
];
---

<BaseLayout
  title="العلم وراء Fluera"
  description="ترتكز Fluera على خمسة عقود من أبحاث الذاكرة — Bjork وMueller وvan der Meer وRoediger، وعلم أعصاب خلايا المكان الحاصل على نوبل. اكتشف دورة الـ12 خطوة والمبادئ وراء كلّ ميزة."
  locale="ar"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04] relative overflow-hidden noise">
    <div class="glow-orb h-[500px] w-[500px] -top-32 -start-40 bg-accent-ink/25 animate-orb-pulse"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6 text-accent-glow">العلم</p>
        <h1 class="font-serif text-display-2xl text-paper-50 mb-6">
          خمسة عقود من أبحاث الذاكرة<br />وراء تطبيق واحد.
        </h1>
        <p class="prose-ink text-xl max-w-2xl mb-10">
          كلّ ميزة في Fluera تعود إلى أبحاث منشورة. أدناه: دورة التعلّم ذات الـ12 خطوة، و23 مبدأً يقوم عليها، واثنا عشر عقلًا نعتمد عليها، وحدود ما لم نَدّعِه بعد.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#learning-cycle" class="btn-secondary">انتقل إلى الدورة</a>
          <a href="#principles" class="btn-secondary">فهرس المبادئ</a>
          <a href="#authors" class="btn-secondary">المؤلّفون</a>
          <a href="/ar/research" class="btn-secondary">المراجع ←</a>
        </div>
      </div>
    </div>
  </section>

  <section id="learning-cycle" class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">الدورة</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">لوحة واحدة. اثنتا عشرة حركة معرفية.</h2>
        <p class="prose-ink text-lg max-w-prose">
          الدورة متسلسلة وتكرارية. الخطوات 1-4 تبني الترميز. الخطوة 5 (النوم) بيولوجيا غير قابلة للتفاوض. الخطوات 6-9 تُوحِّد على مدى أيّام وأسابيع. الخطوات 10-12 تجعل المعرفة دائمة وقابلة للانتقال.
        </p>
      </div>

      <ol class="max-w-3xl list-none p-0">
        {steps.map((s) => (
          <LearningStep n={s.n} title={s.title} verb={s.verb} description={s.description} />
        ))}
      </ol>
    </div>
  </section>

  <section id="principles" class="py-20 md:py-28 border-b border-white/[0.04] bg-ink-900/40">
    <div class="container-site">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow mb-6 text-accent-glow">فهرس المبادئ</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">23 مبدأً وراء Fluera.</h2>
        <p class="prose-ink text-lg max-w-prose">
          كلّ مبدأ يقود إلى صفحة مخصّصة بالمؤلّفين الرئيسيين والميزات المُطبَّقة والأوراق التي نستشهد بها.
        </p>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {principles.map((p) => (
          <li>
            <a
              href={`/ar/science/principles/${p.id}`}
              class="block card p-5 h-full transition-all hover:border-accent-glow/40 hover:bg-white/[0.04]"
            >
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-serif text-base font-medium text-paper-50 leading-tight">{p.data.title}</h3>
                <span class="shrink-0 text-[10px] font-mono uppercase tracking-widest text-ink-500">{p.data.keyYear}</span>
              </div>
              <p class="text-sm text-paper-300 leading-relaxed line-clamp-3">{p.data.shortDescription}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section id="authors" class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-site">
      <div class="max-w-3xl mb-14">
        <p class="eyebrow mb-6 text-accent-glow">العقول وراء المنهج</p>
        <h2 class="font-serif text-display-xl text-paper-50 mb-6">اثنا عشر باحثًا يعيش عملهم داخل Fluera.</h2>
        <p class="prose-ink text-lg max-w-prose">
          هذه ليست صفحة تكريم. كلّ اسم يقود إلى صفحة تذكر المبدأ، وميزات Fluera التي تُطبّقه، والأوراق التي نستشهد بها.
        </p>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 list-none p-0">
        {authors.map((a) => (
          <li>
            <a href={`/ar/science/authors/${a.id}`} class="block">
              <AuthorCard name={a.data.name} contribution={a.data.shortBio.slice(0, 160) + (a.data.shortBio.length > 160 ? "…" : "")} year={a.data.years} nobel={a.data.nobelLaureate} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04] bg-ink-900/40">
    <div class="container-prose">
      <p class="eyebrow mb-6 text-accent-glow">لماذا اليوم</p>
      <h2 class="font-serif text-display-lg text-paper-50 mb-8">عنق الزجاجة تغيّر.</h2>
      <div class="prose-ink text-lg">
        <p>
          لمعظم التاريخ، كان عنق التعلّم الضيّق هو الوصول. الكتب باهظة، المعلّمون قلّة، المكتبات بعيدة. كان السؤال: <em>هل أستطيع الوصول إلى المعلومة؟</em>
        </p>
        <p>
          للجيل الأخير، كان عنق الزجاجة هو التنقّل. المعلومة وفيرة، إيجاد القطعة الصحيحة هو العمل. Google وWikipedia ودلائل المقرّرات — بنية تحتية كاملة لسؤال واحد: <em>أين هي؟</em>
        </p>
        <p>
          في عام 2026، لم يعد أيّ من ذلك هو عنق الزجاجة. كلّ حقيقة على بعد ثلاث ثوانٍ. كلّ تفسير يمكن توليده بأسلوبك المفضَّل. تغيّر شكل عنق الزجاجة، ولم نَبنِ بعد البنية التحتية للشكل الجديد: <em>كيف نُحوّل ما قرأناه للتوّ إلى شيء نحتفظ به فعلًا؟</em>
        </p>
        <p>
          علم الإدراك لهذا السؤال واضح منذ خمسين عامًا. التكرار المتباعد، ممارسة الاسترجاع، التوليد، الصعوبات المرغوبة، الإدراك المُجسَّد، معايرة ما وراء المعرفة. النتائج قويّة. التحليلات التلوية متّسقة. المشكلة لم تكن أبدًا أن نعرف ما يَعمل — بل أن نَبني أدوات تجعل الفعل الصحيح طريق المقاومة الأقلّ.
        </p>
        <p>
          إغراء عصر النماذج اللغوية معاكس. يجعل الفعل الخاطئ — الاستهلاك السلبي للتفسيرات السلسة — يبدو وكأنّه الفعل الصحيح. تعرّف في ثلاث ثوانٍ يُخلَط بالترميز. لسنا بحاجة إلى تطبيق آخر لتسريع هذا الخطأ.
        </p>
        <p>
          بُنيت Fluera عكس التيّار. بطيئة حيث السرعة وَهْم. هادئة حيث الضجيج نموذج عمل. صعبة حيث الصعوبة آليّة. ليس لأنّنا نحبّ الإجهاد، بل لأنّ الدليل واضح — الجهد <em>هو</em> التعلّم.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 border-b border-white/[0.04]">
    <div class="container-prose">
      <p class="eyebrow mb-6 text-accent-glow">الشفافية</p>
      <h2 class="font-serif text-display-lg text-paper-50 mb-8">ما لا نَدّعيه.</h2>
      <div class="prose-ink text-lg">
        <p>
          نستشهد بالأبحاث لكلّ مبدأ لأنّ الأبحاث موجودة. لا يعني ذلك أنّ Fluera اختُبرت في تجارب ضابطة. لم تختبر — ليس بعد. حين نقول «مبنيّ على الأدلّة»، نعني أنّ الآلية الأساسية موجودة. التطبيق المحدّد رهان هندسي مستنير بالأدبيات.
        </p>
        <p>
          لسنا أداة سريرية. لا نستبدل مدرّسًا كفؤًا. لن نُعلن أنّ استخدام Fluera يرفع نتيجة أيّ طالب بنسبة محدّدة. ادّعاء كهذا سيكون إمّا غير صادق أو غير مُثبَت — كلاهما أسوأ من الصمت.
        </p>
        <p>
          بعض المبادئ المُدرَجة مُختلَف عليها في مجالات محدّدة. تدخّلات عقلية النموّ تُظهر تكرارًا متباينًا في تجارب ضابطة. التدفّق أسهل في التعرّف منه في الهندسة الموثوقة. الإدراك المكاني في البيئات الرقمية لا يطابق دائمًا ذاك في البيئات المادّية.
        </p>
        <p>
          التحليلات التلوية التي نستشهد بها هي أقرب إجماع يُنتجه علم الإدراك. ميزات Fluera المبنيّة عليها هي، في هذه اللحظة، فرضيّات نختبرها مع البيتا. إن كان شيء لا يَعمل لك، نريد أن نعرف — تلك الإشارة أثمن من أيّ ادّعاء على صفحة هبوط.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-ink-900/40">
    <div class="container-narrow text-center">
      <h2 class="font-serif text-display-lg text-paper-50 mb-4">جرّب الدورة.</h2>
      <p class="prose-ink mb-8 max-w-2xl mx-auto">
        القراءة عن ممارسة الاسترجاع ليست ممارسة الاسترجاع. انضمّ إلى البيتا الخاصّة واختبر الدورة على لوحتك.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/beta" class="btn-primary">انضمّ إلى البيتا ←</a>
        <a href="/ar/research" class="btn-secondary">اقرأ المراجع</a>
      </div>
    </div>
  </section>

</BaseLayout>
