---
import BaseLayout from "@/layouts/BaseLayout.astro";

const pageTitle = "Fluera Engine — Professional 2D Canvas SDK for Flutter";
const pageDescription =
  "Pressure-sensitive brushes. Infinite canvas. Scene graph. Real-time collaboration. The engine behind Fluera, now as a commercial SDK for your Flutter app.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-16 text-center">
    <p class="mb-5 inline-block rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs tracking-wide text-white/60 uppercase">
      Fluera Engine SDK · v0.1.0
    </p>
    <h1 class="font-display text-balance text-5xl leading-tight font-bold md:text-6xl">
      The canvas engine behind Fluera,<br/>
      <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
        now shipping as a Flutter SDK.
      </span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-white/70">
      Pressure-sensitive brushes. Infinite canvas. Scene graph. 60 FPS
      rendering. Everything we built for the consumer app, packaged so you
      can drop it into yours in an afternoon.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="#pricing"
        class="rounded-xl bg-purple-500 px-6 py-3 font-semibold text-white shadow-lg shadow-purple-500/30 hover:bg-purple-400"
      >
        Get a licence →
      </a>
      <a
        href="https://github.com/looponia/fluera_engine"
        class="rounded-xl border border-white/15 bg-white/5 px-6 py-3 font-semibold text-white hover:bg-white/10"
      >
        View on GitHub
      </a>
      <a
        href="#demos"
        class="rounded-xl border border-white/15 bg-white/5 px-6 py-3 font-semibold text-white hover:bg-white/10"
      >
        Run the 5 demos
      </a>
    </div>
  </section>

  <!-- ═══════════════════════ CODE SNIPPET ═══════════════════════ -->
  <section class="mx-auto max-w-4xl px-6 pb-20">
    <div class="rounded-2xl border border-white/10 bg-black/60 p-6 shadow-2xl">
      <pre class="overflow-x-auto text-sm leading-relaxed text-white/90"><code>{`import 'package:fluera_engine/fluera_engine.dart';

// A drawing canvas in ~5 lines of wiring.
final controller = InfiniteCanvasController();

InfiniteCanvasGestureDetector(
  controller: controller,
  onDrawStart: (pos, pressure, tiltX, tiltY) { /* push stroke */ },
  onDrawUpdate: (pos, pressure, tiltX, tiltY) { /* extend stroke */ },
  onDrawEnd: (pos) { /* commit stroke */ },
  child: CustomPaint(painter: YourScenePainter(), size: Size.infinite),
);`}</code></pre>
    </div>
  </section>

  <!-- ══════════════════════ FEATURE MATRIX ══════════════════════ -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="mb-12 text-center font-display text-4xl font-bold">
      Two layers. One engine.
    </h2>

    <div class="grid gap-6 md:grid-cols-2">
      <!-- CORE -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-green-500/15 px-3 py-1 text-xs font-semibold text-green-300">
          MIT · FREE
        </div>
        <h3 class="mb-2 text-2xl font-bold">Core</h3>
        <p class="mb-5 text-white/60">
          Everything you need to build a drawing surface. Open source.
          Adoption-friendly.
        </p>
        <ul class="space-y-2 text-sm text-white/80">
          <li>✓ Infinite canvas controller + pressure/tilt gesture detector</li>
          <li>✓ Scene graph with 5 base node types (stroke, shape, text, image, layer)</li>
          <li>✓ 3 base brushes: ballpoint, pencil, highlighter</li>
          <li>✓ Pen, eraser, shape, text, image tools</li>
          <li>✓ Undo/redo with delta tracking</li>
          <li>✓ PNG / JPEG / WebP export</li>
          <li>✓ Module system for plugins</li>
          <li>✓ iOS · Android · Linux · macOS · Windows · Web</li>
        </ul>
      </div>

      <!-- PRO -->
      <div class="rounded-2xl border border-purple-500/40 bg-gradient-to-b from-purple-500/10 to-transparent p-8">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-purple-500/20 px-3 py-1 text-xs font-semibold text-purple-200">
          COMMERCIAL
        </div>
        <h3 class="mb-2 text-2xl font-bold">Pro</h3>
        <p class="mb-5 text-white/60">
          The advanced systems we built over 18 months. One-time purchase.
        </p>
        <ul class="space-y-2 text-sm text-white/80">
          <li>★ 14 GPU shader renderers</li>
          <li>★ Advanced brushes: watercolor, charcoal, fountain pen, nib</li>
          <li>★ Real-time CRDT collaboration</li>
          <li>★ Timeline branching with 3-way merge</li>
          <li>★ Time travel stroke playback</li>
          <li>★ SQLCipher encrypted storage</li>
          <li>★ PDF + SVG export, LaTeX recognition</li>
          <li>★ Tile-cached rendering with LOD + occlusion culling</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ COMPARISON TABLE ══════════════════════ -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="mb-12 text-center font-display text-4xl font-bold">
      How it compares in the Flutter ecosystem
    </h2>

    <div class="overflow-x-auto rounded-2xl border border-white/10 bg-white/5">
      <table class="w-full text-sm">
        <thead class="border-b border-white/10 bg-black/30">
          <tr>
            <th class="p-4 text-left text-white/80">Feature</th>
            <th class="p-4 text-center text-purple-300">Fluera Engine</th>
            <th class="p-4 text-center text-white/60">flutter_drawing_board</th>
            <th class="p-4 text-center text-white/60">scribble</th>
            <th class="p-4 text-center text-white/60">fldraw</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          {[
            ["Pressure-sensitive brushes", "✅", "❌", "✅", "❌"],
            ["Infinite canvas (unbounded pan/zoom)", "✅", "❌", "❌", "✅"],
            ["Scene graph (layers, groups, frames)", "✅", "❌", "❌", "❌"],
            ["GPU shader renderers (Pro)", "✅", "❌", "❌", "❌"],
            ["Real-time collaboration (Pro)", "✅ CRDT", "❌", "❌", "❌"],
            ["Time travel playback (Pro)", "✅", "❌", "❌", "❌"],
            ["Commercial support & SLA", "✅", "❌", "❌", "❌"],
          ].map((row) => (
            <tr>
              <td class="p-4 text-white/80">{row[0]}</td>
              <td class="p-4 text-center font-semibold text-purple-300">{row[1]}</td>
              <td class="p-4 text-center text-white/50">{row[2]}</td>
              <td class="p-4 text-center text-white/50">{row[3]}</td>
              <td class="p-4 text-center text-white/50">{row[4]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ═══════════════════════ PRICING ═══════════════════════ -->
  <section id="pricing" class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="mb-4 text-center font-display text-4xl font-bold">
      Pricing
    </h2>
    <p class="mx-auto mb-12 max-w-2xl text-center text-white/60">
      One-time licences. Perpetual fallback: if you stop paying for updates,
      you keep the version you had. No per-seat fees. No rug pulls.
    </p>

    <div class="grid gap-6 md:grid-cols-3">
      <!-- Startup -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
        <div class="mb-2 text-xs font-semibold tracking-wide text-white/60 uppercase">
          Startup
        </div>
        <div class="mb-1 text-4xl font-bold">
          €499<span class="text-lg text-white/50">/once</span>
        </div>
        <div class="mb-5 text-sm text-white/60">
          + €149/year for updates (optional)
        </div>
        <ul class="mb-8 space-y-2 text-sm text-white/80">
          <li>Revenue cap &lt; $100k/year</li>
          <li>All Pro features</li>
          <li>12 months updates included</li>
          <li>Email support</li>
        </ul>
        <a
          href="mailto:hello@fluera.dev?subject=Fluera%20Engine%20Startup%20licence"
          class="block rounded-xl bg-white/10 px-5 py-3 text-center font-semibold hover:bg-white/20"
        >
          Buy licence
        </a>
      </div>

      <!-- Pro / Studio -->
      <div class="rounded-2xl border border-purple-500/60 bg-gradient-to-b from-purple-500/20 to-transparent p-8 shadow-xl shadow-purple-500/10">
        <div class="mb-2 inline-block rounded-full bg-purple-500 px-3 py-0.5 text-xs font-bold text-white">
          MOST POPULAR
        </div>
        <div class="mb-2 text-xs font-semibold tracking-wide text-white/60 uppercase">
          Pro / Studio
        </div>
        <div class="mb-1 text-4xl font-bold">
          €1,499<span class="text-lg text-white/50">/once</span>
        </div>
        <div class="mb-5 text-sm text-white/60">
          + €399/year for updates (optional)
        </div>
        <ul class="mb-8 space-y-2 text-sm text-white/80">
          <li>Revenue cap &lt; $1M/year</li>
          <li>All Pro features</li>
          <li>12 months updates included</li>
          <li>Priority email support</li>
          <li>Up to 5 developer seats</li>
        </ul>
        <a
          href="mailto:hello@fluera.dev?subject=Fluera%20Engine%20Pro%20licence"
          class="block rounded-xl bg-purple-500 px-5 py-3 text-center font-semibold hover:bg-purple-400"
        >
          Buy licence
        </a>
      </div>

      <!-- Enterprise -->
      <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
        <div class="mb-2 text-xs font-semibold tracking-wide text-white/60 uppercase">
          Enterprise
        </div>
        <div class="mb-1 text-4xl font-bold">
          €5k–15k<span class="text-lg text-white/50">/year</span>
        </div>
        <div class="mb-5 text-sm text-white/60">
          Continuous subscription, tailored to your scale
        </div>
        <ul class="mb-8 space-y-2 text-sm text-white/80">
          <li>Unlimited revenue / seats</li>
          <li>SLA, priority response</li>
          <li>Roadmap influence (1 custom feature/year)</li>
          <li>Source code escrow</li>
          <li>2 video training sessions</li>
        </ul>
        <a
          href="mailto:hello@fluera.dev?subject=Fluera%20Engine%20Enterprise"
          class="block rounded-xl bg-white/10 px-5 py-3 text-center font-semibold hover:bg-white/20"
        >
          Request a quote
        </a>
      </div>
    </div>

    <p class="mt-10 text-center text-sm text-white/50">
      Questions? Write to{" "}
      <a class="text-purple-300 hover:underline" href="mailto:hello@fluera.dev">
        hello@fluera.dev
      </a>
      . Usually a reply within a day.
    </p>
  </section>

  <!-- ═══════════════════════ DEMOS ═══════════════════════ -->
  <section id="demos" class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="mb-4 text-center font-display text-4xl font-bold">
      5 runnable demos
    </h2>
    <p class="mx-auto mb-12 max-w-2xl text-center text-white/60">
      Clone the repo, run <code class="rounded bg-black/40 px-1.5 py-0.5">flutter run</code>,
      pick the demo closest to what you're building. Each is ≤300 lines.
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: "🖌️", title: "Hello Canvas", desc: "Drawing surface with pan, zoom, undo, clear, color palette." },
        { icon: "✍️", title: "Pressure & Tilt", desc: "Live stylus input readout (Apple Pencil, S Pen)." },
        { icon: "🧩", title: "Scene Manipulation", desc: "Programmatic stroke push — no gestures needed." },
        { icon: "🎨", title: "Custom Brush", desc: "Swap the renderer: rainbow, dotted, calligraphy nib." },
        { icon: "💾", title: "Export PNG", desc: "Rasterize the canvas to a PNG byte array." },
      ].map((d) => (
        <div class="rounded-xl border border-white/10 bg-white/5 p-5">
          <div class="mb-2 text-3xl">{d.icon}</div>
          <h3 class="mb-1 font-semibold">{d.title}</h3>
          <p class="text-sm text-white/60">{d.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="https://github.com/looponia/fluera_engine_examples"
        class="inline-block rounded-xl border border-white/15 bg-white/5 px-6 py-3 font-semibold hover:bg-white/10"
      >
        Clone fluera_engine_examples →
      </a>
    </div>
  </section>

  <!-- ═══════════════════════ FINAL CTA ═══════════════════════ -->
  <section class="mx-auto max-w-4xl px-6 py-24 text-center">
    <h2 class="font-display text-4xl font-bold">
      Built in 18 months. Yours to use today.
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-white/70">
      Stop rebuilding a pressure-aware canvas from scratch for every project.
      Start with a production-grade engine used in a live consumer app.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="#pricing"
        class="rounded-xl bg-purple-500 px-6 py-3 font-semibold text-white shadow-lg shadow-purple-500/30 hover:bg-purple-400"
      >
        Get a licence →
      </a>
      <a
        href="mailto:hello@fluera.dev"
        class="rounded-xl border border-white/15 bg-white/5 px-6 py-3 font-semibold hover:bg-white/10"
      >
        Talk to the founder
      </a>
    </div>
  </section>
</BaseLayout>
