---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const features = (await getCollection("features", ({ data }) => data.lang === "en")).sort(
  (a, b) => a.data.order - b.data.order,
);

const statusLabel: Record<string, string> = {
  stable: "उपलब्ध",
  beta: "बीटा",
  "coming-soon": "जल्द आ रहा है",
};

const statusStyle: Record<string, string> = {
  stable:        "text-signal-ok border-signal-ok/30",
  beta:          "text-accent-glow border-accent-glow/30",
  "coming-soon": "text-signal-warn border-signal-warn/30",
};
---

<BaseLayout
  title="विशेषताएं"
  description="Ghost Map, Atlas, Socratic Mode, Fog of War, Cross-Zone Bridges, Exam Session, Reflow, अंतराल पुनरावृत्ति। हर विशेषता एक उद्धृत सिद्धांत पर वापस जाती है।"
  locale="hi"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04] relative overflow-hidden noise">
    <div class="glow-orb h-[420px] w-[420px] -top-40 -end-32 bg-accent-glow/20 animate-orb-pulse"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6 text-accent-glow">विशेषताएं</p>
        <h1 class="font-serif text-display-2xl text-paper-50 mb-6">
          स्मृति बनने<br />के आठ तरीके।
        </h1>
        <p class="prose-ink text-xl max-w-2xl">
          प्रत्येक विशेषता 12-चरण अधिगम चक्र के एक विशिष्ट चरण में स्थित है। प्रत्येक विज्ञान पृष्ठ पर एक या अधिक सिद्धांतों पर वापस जाती है। हर विशेषता एक उद्धरण के साथ खुद को बचाती है।
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 border-b border-white/[0.04]">
    <div class="container-site">
      <ul class="space-y-6 list-none p-0 max-w-5xl">
        {features.map((f) => (
          <li>
            <a href={`/hi/features/${f.id}`} class="block card p-8 md:p-10 hover:border-accent-glow/40 hover:bg-white/[0.04] transition-all">
              <div class="grid md:grid-cols-3 gap-8 items-start">
                <div class="md:col-span-2">
                  <div class="flex items-center gap-3 mb-4 flex-wrap">
                    {f.data.stepInCycle && (
                      <span class="eyebrow text-accent-glow">चरण {f.data.stepInCycle}</span>
                    )}
                    <span class={`pill text-[10px] capitalize ${statusStyle[f.data.status]}`}>
                      {statusLabel[f.data.status]}
                    </span>
                  </div>
                  <h2 class="font-serif text-display-lg text-paper-50 mb-4">{f.data.title}</h2>
                  <p class="prose-ink text-lg mb-4 max-w-prose">{f.data.tagline}</p>
                  <p class="text-sm text-paper-300 max-w-prose">{f.data.shortDescription}</p>
                </div>
                <div class="flex md:justify-end items-start">
                  <span class="text-accent-glow text-sm font-mono uppercase tracking-widest">गहरी जानकारी →</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-20 bg-ink-900/40">
    <div class="container-narrow text-center">
      <h2 class="font-serif text-display-lg text-paper-50 mb-4">सभी को बीटा में आज़माएं।</h2>
      <p class="prose-ink mb-8 max-w-2xl mx-auto">
        विशेषताएं पहले iOS और macOS पर आती हैं, फिर Android और डेस्कटॉप। निजी बीटा में शामिल हों और वह प्लेटफॉर्म चुनें जिस पर आप जल्दी पहुंच चाहते हैं।
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/beta" class="btn-primary">एक्सेस का अनुरोध करें →</a>
        <a href="/hi/" class="btn-secondary">होम पर वापस</a>
      </div>
    </div>
  </section>

</BaseLayout>
