---
import DocLayout from "@/layouts/DocLayout.astro";
import { getCollection, render } from "astro:content";
import { buildEngineDocsSections } from "@/lib/docs-nav";

export async function getStaticPaths() {
  const docs = await getCollection("engineDocs");
  return docs.map((d) => ({ params: { slug: d.id }, props: { doc: d } }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const sections = await buildEngineDocsSections();
---

<DocLayout
  title={doc.data.title}
  description={doc.data.description}
  sections={sections}
  rootHref="/engine/docs"
  rootLabel="SDK docs"
  sectionLabel={doc.data.sectionLabel}
>
  {(doc.data.apiSignature || doc.data.since) && (
    <div class="mb-8 p-4 rounded-xl border border-white/[0.08] bg-ink-900/60 font-mono text-sm flex flex-wrap items-center justify-between gap-3">
      {doc.data.apiSignature && (
        <code class="text-accent-glow">{doc.data.apiSignature}</code>
      )}
      {doc.data.since && (
        <span class="text-xs uppercase tracking-widest text-ink-500">Since {doc.data.since}</span>
      )}
    </div>
  )}

  <Content />
</DocLayout>
