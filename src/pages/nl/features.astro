---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const features = (await getCollection("features", ({ data }) => data.lang === "nl")).sort(
  (a, b) => a.data.order - b.data.order,
);

const statusLabel: Record<string, string> = {
  stable: "Beschikbaar",
  beta: "In beta",
  "coming-soon": "Binnenkort",
};

const statusStyle: Record<string, string> = {
  stable:        "text-signal-ok border-signal-ok/30",
  beta:          "text-accent-glow border-accent-glow/30",
  "coming-soon": "text-signal-warn border-signal-warn/30",
};
---

<BaseLayout
  title="Functies"
  description="Ghost Map, Atlas, Socratic Mode, Fog of War, Cross-Zone Bridges, Exam Session, Reflow, gespreide herhaling. Elke functie verwijst naar een aangehaald principe."
  locale="nl"
>

  <section class="py-20 md:py-28 border-b border-white/[0.04] relative overflow-hidden noise">
    <div class="glow-orb h-[420px] w-[420px] -top-40 -end-32 bg-accent-glow/20 animate-orb-pulse"></div>
    <div class="container-site relative">
      <div class="max-w-3xl">
        <p class="eyebrow mb-6 text-accent-glow">Functies</p>
        <h1 class="font-serif text-display-2xl text-paper-50 mb-6">
          Acht manieren<br />waarop geheugen wordt opgebouwd.
        </h1>
        <p class="prose-ink text-xl max-w-2xl">
          Elke functie leeft in een specifieke stap van de leercyclus in 12 fasen. Elke verwijst naar één of meer principes op de wetenschapspagina's. Elke functie verdedigt zichzelf met een citaat.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 border-b border-white/[0.04]">
    <div class="container-site">
      <ul class="space-y-6 list-none p-0 max-w-5xl">
        {features.map((f) => (
          <li>
            <a href={`/nl/features/${f.id.replace(/\.nl$/, "")}`} class="block card p-8 md:p-10 hover:border-accent-glow/40 hover:bg-white/[0.04] transition-all">
              <div class="grid md:grid-cols-3 gap-8 items-start">
                <div class="md:col-span-2">
                  <div class="flex items-center gap-3 mb-4 flex-wrap">
                    {f.data.stepInCycle && (
                      <span class="eyebrow text-accent-glow">Stap {f.data.stepInCycle}</span>
                    )}
                    <span class={`pill text-[10px] capitalize ${statusStyle[f.data.status]}`}>
                      {statusLabel[f.data.status]}
                    </span>
                  </div>
                  <h2 class="font-serif text-display-lg text-paper-50 mb-4">{f.data.title}</h2>
                  <p class="prose-ink text-lg mb-4 max-w-prose">{f.data.tagline}</p>
                  <p class="text-sm text-paper-300 max-w-prose">{f.data.shortDescription}</p>
                </div>
                <div class="flex md:justify-end items-start">
                  <span class="text-accent-glow text-sm font-mono uppercase tracking-widest">Verdiepen →</span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-20 bg-ink-900/40">
    <div class="container-narrow text-center">
      <h2 class="font-serif text-display-lg text-paper-50 mb-4">Test ze allemaal in de beta.</h2>
      <p class="prose-ink mb-8 max-w-2xl mx-auto">
        De functies komen eerst op iOS en macOS, daarna op Android en desktop. Word lid van de private beta en kies het platform waarop je vroege toegang wilt.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/beta" class="btn-primary">Toegang aanvragen →</a>
        <a href="/nl/" class="btn-secondary">Terug naar home</a>
      </div>
    </div>
  </section>

</BaseLayout>
