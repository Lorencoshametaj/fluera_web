---
import DocLayout from "@/layouts/DocLayout.astro";
import { docSeo } from "@/lib/seo-templates";
import { getCollection, getEntry, render } from "astro:content";
import { buildDocsSections } from "@/lib/docs-nav";

export async function getStaticPaths() {
  const docs = await getCollection("docs", ({ data }) => data.lang === "en");
  return docs.map((d) => ({ params: { slug: d.id }, props: { doc: d } }));
}

const { doc } = Astro.props;
// SEO: JSON-LD schema + hreflang alternates (multi-locale aware).
const allDocs = await getCollection("docs", () => true);
const seo = docSeo({ doc, allDocs, pathname: Astro.url.pathname });
const { Content } = await render(doc);
const sections = await buildDocsSections("en");

const relatedDocs = await Promise.all(
  doc.data.relatedDocs.map((ref) => getEntry(ref)),
);
---

<DocLayout
  jsonLd={seo.jsonLd}
  alternates={seo.alternates}
  title={doc.data.title}
  description={doc.data.description}
  sections={sections}
  rootHref="/docs"
  rootLabel="User docs"
  sectionLabel={doc.data.sectionLabel}
  updatedAt={doc.data.updatedAt}
>
  <Content />

  {relatedDocs.length > 0 && (
    <section class="mt-16 pt-8 border-t border-white/[0.06]">
      <h3 class="font-serif text-lg text-paper-50 mb-3">Related</h3>
      <ul>
        {relatedDocs.map((d) => (
          <li><a href={`/docs/${d.id}`}>{d.data.title}</a></li>
        ))}
      </ul>
    </section>
  )}
</DocLayout>
