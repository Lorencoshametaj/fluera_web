---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? "";
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "";
const configured =
  supabaseUrl &&
  supabaseKey &&
  !supabaseUrl.includes("YOUR-PROJECT-REF") &&
  !supabaseKey.includes("YOUR_ANON");

const description =
  "Entre na closed beta do Fluera: canvas infinito + IA + ciência cognitiva da aprendizagem. Acesso por turmas.";
---

<BaseLayout
  title="Beta Fluera — O estudo baseado em ciência cognitiva"
  description={description}
  locale="pt-br"
>

  <!-- HERO + INFO -->
  <section class="relative py-20 md:py-28 overflow-hidden noise">
    <div class="glow-orb h-[400px] w-[400px] -top-24 -start-36 bg-accent-ink/30 animate-orb-pulse"></div>
    <div class="glow-orb h-[350px] w-[350px] top-24 -end-24 bg-accent-glow/25 animate-orb-pulse" style="animation-delay: -2s"></div>

    <div class="container-narrow relative text-center">
      <div class="pill mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-accent-glow animate-pulse"></span>
        Closed beta · Acesso por turmas
      </div>
      <h1 class="font-serif text-display-xl text-paper-50 mb-6">
        Estudar com base na<br />
        <span class="text-gradient">ciência cognitiva</span>
      </h1>
      <p class="prose-ink text-lg mb-10 max-w-2xl mx-auto">
        Canvas infinito, IA integrada, ciclo de aprendizagem em 12 passos baseado em
        <em>repetição espaçada</em>, <em>prática de recuperação</em> e <em>falha produtiva</em>.
        Não é um app para desenhar nem um substituto do Anki: é o ponto onde os dois se encontram.
      </p>

      <div class="grid sm:grid-cols-3 gap-4 text-start max-w-2xl mx-auto">
        <div class="card p-4">
          <p class="font-serif text-sm font-medium text-paper-50 mb-1.5">Ghost Map</p>
          <p class="text-xs text-paper-300 leading-relaxed">
            A IA desenha com você o mapa conceitual e mostra o que está faltando.
          </p>
        </div>
        <div class="card p-4">
          <p class="font-serif text-sm font-medium text-paper-50 mb-1.5">FSRS personalizado</p>
          <p class="text-xs text-paper-300 leading-relaxed">
            Repetição espaçada moderna, calibrada nos seus reviews reais.
          </p>
        </div>
        <div class="card p-4">
          <p class="font-serif text-sm font-medium text-paper-50 mb-1.5">Socratic Mode</p>
          <p class="text-xs text-paper-300 leading-relaxed">
            A IA faz perguntas em vez de dar respostas. Você pensa de verdade.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM -->
  <section class="pb-24">
    <div class="container-narrow max-w-xl">

      {!configured && (
        <div class="mb-6 rounded-xl border border-dashed border-signal-bad/40 bg-signal-bad/[0.08] px-4 py-3 text-xs font-mono text-red-300">
          ⚠️ Configure <code>PUBLIC_SUPABASE_URL</code> e <code>PUBLIC_SUPABASE_ANON_KEY</code> em <code>.env</code> antes do deploy.
        </div>
      )}

      <div class="card p-6 md:p-8">
        <h2 class="font-serif text-xl text-paper-50 mb-1">Solicitar acesso</h2>
        <p class="text-sm text-ink-500 mb-6">
          As respostas aqui ajudam a entender <em>quem</em> convidar primeiro. Quanto mais honesto, melhor.
        </p>

        <form id="waitlist-form" novalidate>
          <div class="honeypot" aria-hidden="true">
            <label>Não preencher: <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </div>

          <div class="space-y-5">
            <div>
              <label class="field-label" for="f-name">Nome (opcional)</label>
              <input id="f-name" name="name" type="text" class="field-input" placeholder="Como podemos te chamar?" maxlength="80" autocomplete="given-name" />
            </div>

            <div>
              <label class="field-label" for="f-email">E-mail <span class="text-signal-bad">*</span></label>
              <input id="f-email" name="email" type="email" class="field-input" placeholder="voce@example.com" required maxlength="254" autocomplete="email" />
              <p class="field-hint">Use o e-mail que você acompanha — vamos escrever a partir daqui.</p>
            </div>

            <div>
              <span class="field-label">Você estuda ou trabalha? <span class="text-signal-bad">*</span></span>
              <div class="flex flex-wrap gap-2 mt-1">
                <label class="role-pill"><input type="radio" name="role" value="student" required> Estudante</label>
                <label class="role-pill"><input type="radio" name="role" value="professional"> Profissional / knowledge worker</label>
                <label class="role-pill"><input type="radio" name="role" value="educator"> Docente / faculdade</label>
                <label class="role-pill"><input type="radio" name="role" value="other"> Outro</label>
              </div>
            </div>

            <div data-show-when-role="student educator">
              <label class="field-label" for="f-faculty">Faculdade ou área de estudo</label>
              <input id="f-faculty" name="faculty" type="text" class="field-input" placeholder="Ex.: Medicina, Engenharia da Computação…" minlength="2" maxlength="120" />
              <p class="field-hint">Obrigatório se você for estudante ou docente.</p>
            </div>

            <div data-show-when-role="professional">
              <label class="field-label" for="f-domain">Área de trabalho</label>
              <input id="f-domain" name="work_domain" type="text" class="field-input" placeholder="Ex.: Product designer, pesquisador biotech, advogado…" minlength="2" maxlength="120" />
              <p class="field-hint">No que você pensa o dia inteiro.</p>
            </div>

            <div data-show-when-role="student">
              <label class="field-label" for="f-year">Período de estudo</label>
              <select id="f-year" name="study_year" class="field-select">
                <option value="" disabled selected>Selecione…</option>
                <option value="0">Ensino médio / pré-vestibular</option>
                <option value="1">1º ano</option>
                <option value="2">2º ano</option>
                <option value="3">3º ano</option>
                <option value="4">4º ano</option>
                <option value="5">5º ano</option>
                <option value="6">6º ano</option>
                <option value="7">Em atraso / repetente</option>
                <option value="8">Especialização / mestrado / doutorado</option>
              </select>
            </div>

            <div>
              <label class="field-label" for="f-device">Dispositivo principal <span class="text-signal-bad">*</span></label>
              <select id="f-device" name="device" class="field-select" required>
                <option value="" disabled selected>Selecione…</option>
                <option value="ipad">iPad + Apple Pencil</option>
                <option value="iphone">iPhone</option>
                <option value="android_tablet">Tablet Android + caneta</option>
                <option value="android_phone">Smartphone Android</option>
                <option value="macos">Mac (MacBook / iMac)</option>
                <option value="windows">PC Windows</option>
                <option value="linux">Linux desktop</option>
                <option value="web">Navegador</option>
                <option value="altro">Outro</option>
              </select>
              <p class="field-hint">Onde você pensa todos os dias.</p>
            </div>

            <div>
              <span class="field-label">O que você usa hoje? <span class="text-ink-500 font-normal">(escolha quantos quiser)</span></span>
              <div class="flex flex-wrap gap-2 mt-1">
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="anki"> Anki</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="notability"> Notability</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="goodnotes"> GoodNotes</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="onenote"> OneNote</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="obsidian"> Obsidian</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="notion"> Notion</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="paper"> Papel e caneta</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="pdf_reader"> Leitor de PDF</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="nessuno"> Nenhum</label>
                <label class="tool-pill"><input type="checkbox" name="current_tools" value="altro"> Outro</label>
              </div>
            </div>

            <div>
              <label class="field-label" for="f-pain">
                Qual é o momento mais frustrante em como você estuda ou pensa hoje? <span class="text-signal-bad">*</span>
              </label>
              <textarea id="f-pain" name="main_pain" rows="4" class="field-textarea"
                placeholder="Conte direito. 2-3 linhas bastam — pense no que você gostaria de resolver."
                required minlength="10" maxlength="2000"></textarea>
              <p class="field-hint">Este campo pesa mais do que os outros na seleção.</p>
            </div>

            <div>
              <label class="field-label" for="f-referral">Como você nos conheceu?</label>
              <select id="f-referral" name="referral_source" class="field-select">
                <option value="">Prefiro não dizer</option>
                <option value="reddit">Reddit</option>
                <option value="twitter">Twitter / X</option>
                <option value="tiktok">TikTok</option>
                <option value="instagram">Instagram</option>
                <option value="youtube">YouTube</option>
                <option value="telegram">Telegram / WhatsApp</option>
                <option value="amici">Indicação / amigos</option>
                <option value="google">Busca no Google</option>
                <option value="hn">Hacker News</option>
                <option value="altro">Outro</option>
              </select>
            </div>

            <div class="pt-2">
              <label class="flex items-start gap-3 cursor-pointer">
                <input id="f-consent" type="checkbox" name="consent_privacy" required
                  class="mt-0.5 w-4 h-4 rounded border-white/20 bg-ink-900 text-accent-ink focus:ring-accent-ink" />
                <span class="text-sm text-paper-300 leading-relaxed">
                  Li e aceito a
                  <a href="/legal/privacy" class="text-accent-glow underline">Política de Privacidade</a>
                  e os <a href="/legal/terms" class="text-accent-glow underline">Termos de Uso</a>.
                  Concordo com o tratamento dos dados para ser contatado sobre a closed beta do Fluera.
                </span>
              </label>
            </div>

            <div class="pt-2">
              <button id="submit-btn" type="submit" class="btn-primary w-full py-3.5">
                <span id="submit-label">Entrar na lista de espera</span>
                <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"></circle>
                  <path d="M12 2a10 10 0 0110 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
                </svg>
              </button>

              <div id="status-success" class="hidden mt-5 p-4 rounded-xl border border-signal-ok/30 bg-signal-ok/10">
                <p class="text-sm text-emerald-300 font-medium">Você está na lista.</p>
                <p class="text-xs text-emerald-200/70 mt-1">
                  Vamos escrever de <code>{SITE.company.privacyEmail}</code> assim que abrirmos a próxima vaga.
                </p>
              </div>

              <div id="status-already" class="hidden mt-5 p-4 rounded-xl border border-accent-ink/30 bg-accent-ink/10">
                <p class="text-sm text-blue-200">Esse e-mail já está na lista. Tudo certo 🙂</p>
              </div>

              <div id="status-error" class="hidden mt-5 p-4 rounded-xl border border-signal-bad/30 bg-signal-bad/10">
                <p class="text-sm text-red-300 font-medium">Algo deu errado.</p>
                <p id="status-error-detail" class="text-xs text-red-200/70 mt-1"></p>
              </div>
            </div>
          </div>
        </form>
      </div>

      <p class="text-xs text-ink-500 text-center mt-6">
        As respostas são tratadas conforme nossa <a href="/legal/privacy" class="text-paper-300 underline">Política de Privacidade</a>.
        Não compartilhamos com terceiros nem usamos para publicidade.
      </p>
    </div>
  </section>

  <style>
    .field-label { display: block; font-size: 0.875rem; font-weight: 500; color: theme("colors.paper.200"); margin-bottom: 0.5rem; }
    .field-hint  { font-size: 0.75rem; color: theme("colors.ink.500"); margin-top: 0.375rem; }
    .field-input, .field-select, .field-textarea {
      width: 100%; background: theme("colors.ink.900"); border: 1px solid rgb(255 255 255 / 0.08);
      border-radius: 0.625rem; padding: 0.75rem 1rem; color: theme("colors.paper.50"); font-size: 0.95rem;
      transition: all 0.2s;
    }
    .field-input:focus, .field-select:focus, .field-textarea:focus {
      outline: none; border-color: theme("colors.accent.ink"); box-shadow: 0 0 0 3px rgb(45 74 222 / 0.18);
    }
    .field-input:invalid:not(:placeholder-shown),
    .field-textarea:invalid:not(:placeholder-shown) {
      border-color: rgb(239 68 68 / 0.5);
    }
    .tool-pill, .role-pill {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.5rem 0.875rem; border: 1px solid rgb(255 255 255 / 0.08);
      border-radius: 999px; cursor: pointer; user-select: none;
      background: theme("colors.ink.900"); font-size: 0.875rem; color: theme("colors.paper.200");
      transition: all 0.15s;
    }
    .tool-pill:hover, .role-pill:hover { border-color: rgb(56 189 248 / 0.4); color: theme("colors.paper.50"); }
    .tool-pill input, .role-pill input { display: none; }
    .tool-pill:has(input:checked),
    .role-pill:has(input:checked) {
      background: rgb(45 74 222 / 0.15); border-color: theme("colors.accent.ink"); color: theme("colors.accent.glow");
    }
    [data-show-when-role] { display: none; }
    [data-show-when-role].is-visible { display: block; }
    .honeypot {
      position: absolute; inset-inline-start: -9999px; width: 1px; height: 1px; opacity: 0; pointer-events: none;
    }
  </style>

  <script is:inline define:vars={{ supabaseUrl, supabaseKey, configured }}>
    const form       = document.getElementById("waitlist-form");
    const btn        = document.getElementById("submit-btn");
    const btnLabel   = document.getElementById("submit-label");
    const btnSpinner = document.getElementById("submit-spinner");
    const okBox      = document.getElementById("status-success");
    const dupeBox    = document.getElementById("status-already");
    const errBox     = document.getElementById("status-error");
    const errDetail  = document.getElementById("status-error-detail");
    const renderedAt = Date.now();

    const conditionalBlocks = Array.from(form.querySelectorAll("[data-show-when-role]"));
    const facultyInput = form.querySelector('input[name="faculty"]');
    const domainInput  = form.querySelector('input[name="work_domain"]');
    const yearSelect   = form.querySelector('select[name="study_year"]');

    function applyRoleVisibility() {
      const role = (form.querySelector('input[name="role"]:checked') || {}).value || "";
      conditionalBlocks.forEach((el) => {
        const allowed = (el.getAttribute("data-show-when-role") || "").split(/\s+/);
        const visible = allowed.includes(role);
        el.classList.toggle("is-visible", visible);
        el.querySelectorAll("input, select, textarea").forEach((field) => {
          field.disabled = !visible;
          if (!visible) field.required = false;
        });
      });
      if (facultyInput) facultyInput.required = (role === "student" || role === "educator");
      if (domainInput)  domainInput.required  = (role === "professional");
      if (yearSelect)   yearSelect.required   = (role === "student");
    }
    form.querySelectorAll('input[name="role"]').forEach((r) => r.addEventListener("change", applyRoleVisibility));
    applyRoleVisibility();

    function hideStatuses() {
      okBox.classList.add("hidden");
      dupeBox.classList.add("hidden");
      errBox.classList.add("hidden");
    }
    function setLoading(loading) {
      btn.disabled = loading;
      btnLabel.textContent = loading ? "Enviando…" : "Entrar na lista de espera";
      btnSpinner.classList.toggle("hidden", !loading);
    }
    function showError(msg) { errDetail.textContent = msg; errBox.classList.remove("hidden"); }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideStatuses();

      if (!form.checkValidity()) { form.reportValidity(); return; }
      if (!configured) {
        showError("Backend não configurado. Defina PUBLIC_SUPABASE_URL + anon key em .env.");
        return;
      }
      if (Date.now() - renderedAt < 2000) {
        okBox.classList.remove("hidden"); form.reset(); return;
      }

      const formData = new FormData(form);
      const tools = Array.from(
        form.querySelectorAll('input[name="current_tools"]:checked')
      ).map(i => i.value);

      const role = formData.get("role") || "";
      const facultyVal = (formData.get("faculty") || "").trim();
      const domainVal  = (formData.get("work_domain") || "").trim();
      const yearRaw    = formData.get("study_year");
      const yearVal    = yearRaw ? parseInt(yearRaw, 10) : null;

      const payload = {
        p_email:           (formData.get("email") || "").trim(),
        p_faculty:         facultyVal || domainVal || role,
        p_study_year:      Number.isFinite(yearVal) ? yearVal : 9,
        p_device:          formData.get("device"),
        p_current_tools:   tools,
        p_main_pain:       (formData.get("main_pain") || "").trim(),
        p_consent_privacy: formData.get("consent_privacy") === "on",
        p_name:            (formData.get("name") || "").trim() || null,
        p_referral_source: formData.get("referral_source") || null,
        p_locale:          navigator.language || null,
        p_user_agent:      navigator.userAgent.slice(0, 500),
        p_honeypot:        (formData.get("website") || "").trim() || null,
      };

      setLoading(true);
      try {
        const resp = await fetch(`${supabaseUrl}/rest/v1/rpc/submit_waitlist`, {
          method: "POST",
          headers: {
            apikey: supabaseKey,
            Authorization: `Bearer ${supabaseKey}`,
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(payload),
        });
        if (!resp.ok) throw new Error((await resp.text()) || `HTTP ${resp.status}`);
        const result = await resp.json();
        if (result && result.already_signed) {
          dupeBox.classList.remove("hidden");
        } else {
          okBox.classList.remove("hidden");
          form.reset();
          applyRoleVisibility();
        }
      } catch (err) {
        console.error("Waitlist submit failed:", err);
        showError("Tente novamente em alguns segundos. Se o problema persistir, escreva para support@fluera.dev.");
      } finally {
        setLoading(false);
      }
    });
  </script>

</BaseLayout>
