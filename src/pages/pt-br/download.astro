---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";

const platforms = [
  { name: "iOS / iPadOS", status: "Beta",  note: "Convite TestFlight depois da aprovação na beta." },
  { name: "macOS",        status: "Beta",  note: "Arquivo .dmg por link privado depois da aprovação." },
  { name: "Android",      status: "Alpha", note: "APK via internal track do Google Play." },
  { name: "Windows",      status: "Alpha", note: "Instalador .exe assinado via Microsoft Store." },
  { name: "Linux",        status: "Alpha", note: "AppImage + flatpak." },
  { name: "Web",          status: "Demo",  note: "Teste agora em /demo — exige navegador com WebGPU." },
];
---

<BaseLayout
  title="Baixar"
  description="Fluera roda nativo em iOS, Android, macOS, Windows, Linux e na web. Entre na beta privada para acesso antecipado."
  locale="pt-br"
>
  <PageHero
    kicker="Baixar"
    title="Seis plataformas.<br />Entre na beta para ter acesso."
    description="Fluera está em beta privada. Uma vez dentro, os links de instalação chegam por e-mail — app nativo em cada plataforma, sem versão web reduzida."
  >
    <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      {platforms.map((p) => (
        <article class="card p-6">
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-serif text-lg text-paper-50">{p.name}</h2>
            <span class="pill text-[10px]">{p.status}</span>
          </div>
          <p class="text-sm text-paper-300 leading-relaxed">{p.note}</p>
        </article>
      ))}
    </div>

    <div class="flex flex-wrap gap-4">
      <a href="/beta" class="btn-primary">Solicitar acesso beta →</a>
      <a href="/beta" class="btn-secondary">Testar a demo web</a>
    </div>
  </PageHero>

  <section class="py-16 border-t border-white/[0.04] bg-ink-900/40">
    <div class="container-narrow text-center">
      <p class="text-sm text-ink-500 max-w-xl mx-auto leading-relaxed">
        Os lançamentos públicos na App Store e no Google Play chegam ao final da beta privada. Enquanto isso, os status acima são honestos sobre a maturidade de cada plataforma — preferimos lançar bem em uma do que mal em seis.
      </p>
    </div>
  </section>
</BaseLayout>
