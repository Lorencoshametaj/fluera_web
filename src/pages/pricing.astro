---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import pricing from "@/data/pricing/en";

const { tiers, faq } = pricing;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<BaseLayout
  title="Pricing"
  description="Free, Plus, Pro. 100 / 500 / 2000 AI credits per month, always visible — no hidden rate limits. Plus €5.99/month, Pro €11.99/month."
  jsonLd={jsonLd}
>
  <PageHero
    kicker="Pricing"
    title="You always know<br />how much AI you have left."
    description="Notion AI throttles you silently. ChatGPT blocks you without warning. We don't: 100, 500 or 2000 credits per month, always visible in the canvas. Whoever subscribes now locks the rate for the lifetime of the subscription."
  >
    <!-- 🎓 Student discount strip (above the fold, no FAQ hunt required) -->
    <a
      href="/contact"
      class="mt-10 flex flex-wrap items-center gap-3 rounded-2xl border border-accent-glow/30 bg-accent-glow/[0.05] px-4 py-3 hover:bg-accent-glow/[0.08] transition-colors"
    >
      <span class="pill text-[10px] text-accent-glow border-accent-glow/40">Students</span>
      <span class="text-sm text-paper-200 flex-1">
        <strong class="text-paper-50">Verified 50% off</strong> with a <code class="font-mono text-xs text-accent-glow">.edu</code> address or student ID — also for European universities without .edu.
      </span>
      <span class="text-xs text-accent-glow font-medium">Apply →</span>
    </a>

    <div class="mt-8 grid md:grid-cols-1 lg:grid-cols-3 gap-4">
        {tiers.map((t) => (
          <article class={`card p-6 flex flex-col ${t.highlighted ? "border-accent-ink/40 bg-accent-ink/[0.05]" : ""}`}>
            <div class="flex items-start justify-between mb-4">
              <h2 class="font-serif text-xl text-paper-50">{t.name}</h2>
              {t.badge && <span class="pill text-[10px] text-accent-glow border-accent-glow/40">{t.badge}</span>}
            </div>

            <div class="mb-5">
              <p class="font-serif text-3xl text-paper-50 mb-1">{t.price}</p>
              <p class="text-xs text-ink-500 font-mono uppercase tracking-widest">{t.period}</p>
            </div>

            <p class="text-sm text-paper-300 mb-6 leading-relaxed">{t.tagline}</p>

            <ul class="space-y-2.5 text-sm mb-8 flex-grow">
              {t.features.map((f) => (
                <li class="flex items-start gap-2.5 text-paper-200">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="shrink-0 mt-0.5 text-accent-glow" aria-hidden="true">
                    <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <a
              href={t.cta.href}
              class={t.highlighted ? "btn-primary" : "btn-secondary"}
            >
              {t.cta.label}
            </a>
          </article>
        ))}
      </div>

    <p class="mt-12 text-xs text-ink-500 max-w-2xl italic">
      List prices may evolve. Whoever subscribes now locks the rate for the lifetime of the subscription. No dark patterns, no surprise auto-renewals: we email before every charge.
    </p>
  </PageHero>

  <!-- FAQ -->
  <section class="py-20 md:py-28">
    <div class="container-site">
      <div class="grid md:grid-cols-3 gap-12">
        <SectionHeader kicker="Frequently asked" title="Questions and answers." titleSize="lg" marginBottom="sm" class="mb-0" />
        <div class="md:col-span-2 divide-y divide-white/[0.06]">
          {faq.map((item) => (
            <details class="group py-5 first:pt-0">
              <summary class="cursor-pointer flex items-start justify-between gap-4 font-serif text-lg text-paper-50 list-none [&::-webkit-details-marker]:hidden">
                <span>{item.q}</span>
                <span class="mt-1.5 text-ink-500 transition-transform group-open:rotate-45" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
                </span>
              </summary>
              <p class="mt-3 text-sm text-paper-300 leading-relaxed max-w-prose">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
